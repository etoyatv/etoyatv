# =========================================================================
# ЭтоЯTV - Шаблон конфигурации переменных окружения (.env)
# Скопируйте этот файл в '.env' и настройте под свою систему.
# =========================================================================

# Порт, на котором будет слушать основное веб-приложение
PORT=3001

# --- Настройки подключения к базе данных MySQL ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=etoyatv

# --- Настройки SMTP (Отправка писем / Восстановление паролей) ---
SMTP_HOST=mail.yourmailserver.com
SMTP_PORT=465
SMTP_USER=no-reply@yourdomain.com
SMTP_PASS=your_smtp_password

# --- Настройки Медиа-сервера и RTMP вещания ---
# Внешний URL API медиа-сервера (для проверки ключей потоков)
RTMP_API_URL=https://rtmp.yourdomain.com

# Публичный HLS URL для воспроизведения плеером (.m3u8)
RTMP_STREAM_URL=https://rtmp.yourdomain.com/live

# Внутренний локальный HLS URL для проверки/создания снапшотов
RTMP_LOCAL_STREAM_URL=http://localhost:8000/live

# URL для вещания в OBS/стримерах
RTMP_INGEST_URL=rtmp://rtmp.yourdomain.com/live

# Права доступа к HTTP API медиа-сервера
RTMP_API_USER=admin
RTMP_API_PASS=admin_password

# --- Настройки путей к медиа-файлам ---
# Путь на диске, где смонтирована сетевая папка или папка статики
MEDIA_STORAGE_PATH=/app/public

# Базовый URL для раздачи статического контента (Оставьте пустым при локальной раздаче, или укажите домен CDN)
CDN_BASE_URL=

# --- URLs для работы авторизации и сессий ---
APP_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002

# Секретный ключ для подписи сессий (сделайте его длинным и случайным)
SESSION_SECRET=some_long_random_session_secret_key

# --- Защита от спама hCaptcha ---
HCAPTCHA_SITEKEY=your_hcaptcha_sitekey
HCAPTCHA_SECRET=your_hcaptcha_secret

# --- Интеграция с Telegram (Админ логи) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=your_telegram_bot_username
