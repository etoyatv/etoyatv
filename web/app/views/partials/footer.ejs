<script>
document.addEventListener("DOMContentLoaded", function() {
  setTimeout(() => {
    // Target EJS status/success/error elements on pages like settings/profile
    const alertDivs = document.querySelectorAll(
      'div[style*="color:#39b54a"], div[style*="color: #39b54a"], ' +
      'div[style*="color:#ff6666"], div[style*="color: #ff6666"]'
    );
    alertDivs.forEach(el => {
      const text = el.textContent || '';
      // Don't fade out persistent critical block errors/warnings
      if (text.includes('отключена') || text.includes('удален') || text.includes('заблокирован') || text.includes('ограничил')) {
        return;
      }
      el.style.transition = 'opacity 0.5s ease-out, height 0.5s ease-out, margin 0.5s ease-out, padding 0.5s ease-out';
      el.style.opacity = '0';
      setTimeout(() => {
        el.style.height = '0';
        el.style.margin = '0';
        el.style.padding = '0';
        el.style.overflow = 'hidden';
        setTimeout(() => el.remove(), 500);
      }, 500);
    });
  }, 5000);
});
</script>
