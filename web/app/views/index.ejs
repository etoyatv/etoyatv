<%- include('partials/header') %>

  <% if (!user) { %>
    <div id="promopage" style="background: #2a3b4e url no-repeat center top; height: 665px; min-width: 1000px;">
      <div class="head"
        style="background: url(/images/bg_1_promo-new.jpg) no-repeat center top; height: 665px; position: relative; overflow: hidden;">
        <div class="channels_logged" style="background: url(/images/css_img_102_carousel-logged.bg.png) no-repeat top left; width: 984px; height: 383px; position: relative; margin: 220px auto 0; padding-top: 35px;">
          <% if (popularChannels.length === 0) { %>
            <div style="padding: 100px 20px; color: #aaa; font-size: 16px; text-align: center; width: 100%;">В данный момент нет телеканалов, ведущих прямую трансляцию</div>
          <% } else { %>
            <ul id="channelscarousel" class="channels_preload jcarousel-skin-channelslogged">
            <% for (let i = 0; i < popularChannels.length; i += 3) { %>
              <li>
                <% for (let j = 0; j < 3; j++) { 
                     let ch = popularChannels[i + j];
                     if (ch) { %>
                  <div class="channel channel-<%= ch.id %>"> 
                    <% 
                      let snapUrl = `/tvsnapshots/${ch.shortname}.jpg`;
                      let logoUrl = ch.logo_url || `/images/default_channel_logo.png`;
                      let bgRule = ch.is_live ? `url('${snapUrl}') center center / cover no-repeat, url('${logoUrl}') center center / contain no-repeat #000` : `url('${logoUrl}') center center / contain no-repeat #000`;
                    %>
                    <a href="/<%= ch.shortname %>" class="thumb" style="background: <%- bgRule %>; position: relative; overflow: hidden;">
                      <% if (ch.is_18_plus) { %>
                      <div style="position: absolute; top: -5px; left: -5px; right: -5px; bottom: -5px; backdrop-filter: blur(15px); background: rgba(0,0,0,0.3); z-index: 1;"></div>
                      <% } %>
                      <span class="border_thumb" style="position: relative; z-index: 2;">
                        <% if (ch.is_premium) { %><div class="premium_label"></div><% } %>
                        <% if (ch.is_live) { %>
                          <div class="live_label"></div>
                        <% } else { %>
                          <div class="online_label"></div>
                        <% } %>
                        <div class="views white"><%= ch.viewers || 0 %></div>
                        <div class="program grey">Телеканал: <span class="blue"><%= ch.name %></span><% if (ch.is_verified) { %><span class="verified_icon" title="Подтвержденный канал"></span><% } %><br>
                          Передача: <span class="white"><%= ch.is_live ? (ch.live_title || ('Передача от ' + formatDate(ch.live_started_at || new Date(), userTimezone, 'DD.MM.YYYY HH:mm'))) : 'Автопилот' %></span>
                        </div>
                      </span>
                    </a> 
                  </div> 
                <% } } %>
              </li>
            <% } %>
            </ul>
          <% } %>
        </div>
      </div>
    </div>
    <script type="text/javascript">
      <!--
        $(document).ready(function () {
          $('#channelscarousel').removeClass('channels_preload').jcarousel({
            scroll: 3,
            animation: 1000,
            itemFirstInCallback: {
              onBeforeAnimation: function () {
                $('.jcarousel-skin-channelslogged .jcarousel-prev').removeClass('jcarousel-prev-disabled').removeClass('jcarousel-prev-disabled-horizontal');
              }
            },
            itemFirstOutCallback: {
              onBeforeAnimation: function () {
                $('.jcarousel-skin-channelslogged .jcarousel-next').removeClass('jcarousel-next-disabled').removeClass('jcarousel-next-disabled-horizontal');
              }
            }
          });
        });
      //-->
    </script>

    <div class="border"></div>
    <div id="content">
      <!--- LEFT COLUMN>> -->
      <div class="left_blocks">
        <!--- CHANNEL NEWS LIST>> -->
        <div class="block_item">

          <div class="blackbox" style="  width: auto;">
            <div class="blackbox_tl"></div>
            <div class="blackbox_tc"></div>
            <div class="blackbox_tr"></div>
            <div class="blackbox_cw">
              <div class="blackbox_c" style="">
                <div class="blackbox_ci">
                  <div class="block-head-bg"></div>
                  <div class="block-head">
                    <div class="block-head-right">
                      <div class="block-title">Новости (<a href="/ru/news" title="Все новости" class="darkblue"><%= typeof newsCount !== "undefined" ? newsCount : 0 %></a>)</div>
                      <div class="block-buttons">
                        <a href="/ru/news" title="Архив новостей" class="block-buttons-bg-last"><span class="block-head-icon-archive"></span></a>
                      </div>
                    </div>
                  </div>
                  <div class="block-content">

                    <div class="news">
                      <% var months=['Января', 'Февраля' , 'Марта' , 'Апреля' , 'Мая' , 'Июня' , 'Июля' , 'Августа' , 'Сентября' , 'Октября' , 'Ноября' , 'Декабря' ]; %>
                      <% latestNews.forEach((item, index)=> { %>
                        <div class="item <%= index === latestNews.length - 1 ? 'last' : '' %> item-<%= item.id %>">
                          <div class="date">
                            <div class="day">
                              <%= ('0' + new Date(item.created_at).getDate()).slice(-2) %>
                            </div>
                            <%= months[new Date(item.created_at).getMonth()] %>
                          </div>
                          <div class="body">
                            <div class="title">
                              <a href="<%= item.is_channel_news ? '/channels/' + item.shortname + '/news/' + item.id : '/ru/news,view,' + item.id %>">
                                <%= item.title %>
                              </a>
                            </div>
                            <div class="announce" style="white-space: pre-line; overflow-wrap: break-word; word-break: break-word;"><%= item.announce %></div>
                          </div>
                          <div class="clear_both"></div>
                        </div>
                      <% }) %>
                      <% if (latestNews.length===0) { %>
                        <p style="color: #c0c0b2;">Новостей пока нет.</p>
                      <% } %>
                    </div>
                  </div>
                  <div class="clear_both"></div>
                </div>
                <div class="clear_both"></div>
              </div>
            </div>
            <div class="blackbox_bl"></div>
            <div class="blackbox_bc"></div>
            <div class="blackbox_br"></div>
          </div>

        </div>
        <!--- <! CHANNEL NEWS LIST -->

      </div>
      <!--- <! LEFT COLUMN -->
      <!--- RIGHT COLUMN>> -->
      <div class="right_blocks">

        <div class="blocks">
          <div class="blackbox" style="  width: auto;">
            <div class="blackbox_tl"></div>
            <div class="blackbox_tc"></div>
            <div class="blackbox_tr"></div>
            <div class="blackbox_cw">
              <div class="blackbox_c" style="">
                <div class="blackbox_ci">
                  <div class="block-head-bg"></div>
                  <div class="block-head">
                    <div class="block-head-right">
                      <div class="block-title">Реклама</div>
                    </div>
                  </div>
                  <div class="block-content">
                    <% if (adsEnabled && adsConfig['sidebar_320x240'] && adsConfig['sidebar_320x240'].image) { %>
                      <div style="width: 320px; display: flex; align-items: center; justify-content: center;">
                        <% if (adsConfig['sidebar_320x240'].url) { %>
                          <a href="<%= adsConfig['sidebar_320x240'].url %>" target="_blank" style="display: block;">
                            <img src="<%= adsConfig['sidebar_320x240'].image %>" style="max-width: 100%;">
                          </a>
                        <% } else { %>
                          <img src="<%= adsConfig['sidebar_320x240'].image %>" style="max-width: 100%;">
                        <% } %>
                      </div>
                    <% } else if (!adsEnabled) { %>
                      <!-- Ad is disabled -->
                    <% } else { %>
                      <div style="width: 320px; height: 240px; background: #333; display: flex; align-items: center; justify-content: center; color: #777;">
                        Место для рекламы
                      </div>
                    <% } %>
                  </div>
                  <div class="clear_both"></div>
                </div>
                <div class="clear_both"></div>
              </div>
            </div>
            <div class="blackbox_bl"></div>
            <div class="blackbox_bc"></div>
            <div class="blackbox_br"></div>
          </div>

        </div>
      </div>
      <!--- <! RIGHT COLUMN -->
      <div class="clear_both"></div>
    </div>
    <div
      style="position:fixed;top:0;bottom:0;width:100%;left:0;right:0;background:#000;opacity:0.85;display:none;z-index:10;"
      id="promobg"></div>
    <div style="position:fixed;height:391px;width:640px;top:150px;left:50%;margin-left:-320px;z-index:11;display:none;"
      id="promoplayer"></div>
    <script type="text/javascript">
      <!--

        function updateThumbnailt(key) {//console.log('updateThumbnailt : '+key); 
          // обновление скриншотов записей...
          $.post('/api/channel,mainpage,ls', {}, function (json) {
            var channels = json.data.list;
            updateImg(channels, key);
          }, 'json');
        };
      function updateImg(channels, key) {//console.log('updateImg : '+key);
        var channel = channels[key];
        var rand = Math.floor(Math.random() * 1000);
        channel.thumbnail = channel.thumbnail ? channel.thumbnail + '?rand=' + rand : '/images/default_channel_logo.png';
        if (document.images) {
          preload_image = new Image(1, 1);
          preload_image.src = channel.thumbnail;
          // если скриншот загрузился
          preload_image.onload = function () {
            var label = '';
            if (channel.is_premium) label += '<div class="premium_label"></div>';
            if (channel.status === 1 || channel.is_live) {
              label += '<div class="live_label"></div>';
            } else {
              label += '<div class="online_label"></div>';
            }
            var verifiedHtml = channel.is_verified ? '<span class="verified_icon" title="Подтвержденный канал"></span>' : '';
            var html = '<a href="' + channel.url + '" class="thumb hidden" style="background: #000 url(' + channel.thumbnail + ') no-repeat center center;display:none;position:absolute;top:0;left:0;">\
      <span class="border_thumb">'+ label + ' \
      <div class="views white">'+ channel.spectators + '</div>\
      <div class="program grey">Телеканал: <span class="blue">'+ truncateStr(channel.title, 20) + '</span>' + verifiedHtml + '<br /> \
      '+ ((typeof (channel.program) != 'undefined') ? 'Передача: <span class="white">' + truncateStr(channel.program.title, 60) + '</span>' : '') + '</div> \
      </span>\
      </a>';
            $('#channelscarousel .channel-' + channel.id + ' .thumb').addClass('last_thumb');
            $('#channelscarousel .channel-' + channel.id).append(html);
            $('#channelscarousel .channel-' + channel.id + ' .hidden').fadeIn(1500, function () {
              var ch = $(this).parent();
              $(this).css({ position: 'relative' }).removeClass('hidden');
              $('.last_thumb', ch).remove();
            });
            // 
            setTimeout(function () { if ((channels.length - 1) == key) { updateThumbnailt(0); } else { key++; updateImg(channels, key); } }, 500);
          }// вслучае если скриншот не подгружается
          preload_image.onError = function () { if ((channels.length - 1) == key) { updateThumbnailt(0); } else { key++; updateImg(channels, key); } }
        }
      } $(document).ready(function () {
        $('#promobg').click(function () {
          $(this).hide();
          $('#promoplayer').hide();
          $('#promobg').hide();
          $('#promoplayer').html('');
        });
      });

      //-->
    </script>

    <% } else { %>


      <div id="promopage_auth" style="background: #2a3b4e url no-repeat center top; height: 681px; min-width: 1000px;">
        <div
          style="background: url(/images/bg_1_promo-new.jpg) no-repeat center top; position: relative; padding-top: 250px; height: 681px; box-sizing: border-box;">

          <!--- Top Banner Removed -->

          <!--- 3 Columns -->
          <div
            style="width: 1000px; margin: 0 auto; display: flex; justify-content: center; align-items: flex-start; text-align: center; color: #fff;">

            <!--- Left: Телеканалы -->
            <div style="width: 300px; padding-top: 30px;">
              <a href="/ru/tv,channels"><img src="<%= CDN_BASE_URL %>/images/telechannel.png" alt="Телеканалы"
                  style="display: block; margin: 0 auto 10px; border: none; max-width: 100%;"></a>
              <div style="font-size: 12px; color: #777; line-height: 1.6;">
                Всего: <span style="color:#6fdeee">
                  <%= totalChannels || 0 %>
                </span> В эфире: <span style="color:#6fdeee">
                  <%= liveChannels || 0 %>
                </span> Зрителей: <span style="color:#6fdeee">
                  <%= totalViewers || 0 %>
                </span><br>
                <a href="/ru/tv,channels" style="color: #6fdeee; text-decoration: none;">Список всех телеканалов</a>
              </div>
            </div>

            <!--- Center: Control Panel / Create Channel -->
            <div style="width: 350px;">
              <% if (typeof userChannel !== 'undefined' && userChannel) { %>
                <a href="/ru/panel,dashboard"><img src="<%= CDN_BASE_URL %>/images/control_panel.png" alt="Панель управления"
                    style="display: block; margin: 0 auto; border: none; max-width: 100%;"></a>
                <% } else { %>
                  <a href="/channels/create"><img src="<%= CDN_BASE_URL %>/images/open_channel.png" alt="Создать телеканал"
                      style="display: block; margin: 0 auto; border: none; max-width: 100%;"></a>
                  <% } %>
            </div>

            <!--- Right: Записи -->
            <div style="width: 300px; padding-top: 47px;">
              <a href="/ru/tv,records"><img src="<%= CDN_BASE_URL %>/images/recorced.png" alt="Записи"
                  style="display: block; margin: 0 auto 10px; border: none; max-width: 100%;"></a>
              <div style="font-size: 12px; color: #777; line-height: 1.6;">
                Всего: <span style="color:#6fdeee">
                  <%= totalRecords || 0 %>
                </span><br>
                <a href="/ru/tv,records" style="color: #6fdeee; text-decoration: none;">Список всех записей</a>
              </div>
            </div>

          </div>

        </div>
      </div>




      <!--- Modern Clean Popular Channels -->
      <div
        style="background: #222; padding: 30px 0; border-top: 1px solid #333; margin-top: -200px; position: relative; z-index: 10;">
        <div style="width: 1000px; margin: 0 auto; position: relative;">
          <div style="text-align: center; margin-bottom: 25px; position: relative;">
            <div style="position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: #333; z-index: 1;">
            </div>
            <span
              style="background: #222; padding: 0 20px; color: #fff; font-size: 18px; position: relative; z-index: 2; font-weight: normal;">Популярные
              телеканалы</span>
          </div>

          <div style="position: relative;">
            <% if (popularChannels.length> 0) { %>
              <button id="scrollLeft"
                style="position: absolute; left: -40px; top: 50%; transform: translateY(-50%); width: 30px; height: 30px; background: transparent; border: none; color: #555; font-size: 30px; cursor: pointer; transition: color 0.2s;">&lt;</button>
              <% } %>

                <div id="channelsContainer"
                  style="display: flex; gap: 18px; overflow-x: auto; scroll-behavior: smooth; padding-bottom: 10px; scrollbar-width: none;">
                  <style>
                    #channelsContainer::-webkit-scrollbar {
                      display: none;
                    }

                    #scrollLeft:hover,
                    #scrollRight:hover {
                      color: #fff !important;
                    }
                  </style>

                  <% if (popularChannels.length===0) { %>
                    <div style="padding: 20px; color: #888; font-size: 14px;">В данный момент нет телеканалов, ведущих
                      прямую трансляцию</div>
                    <% } else { %>
                      <% popularChannels.forEach(function(ch) { %>
                        <a href="/<%= ch.shortname %>"
                          style="flex: 0 0 185px; display: block; width: 185px; text-decoration: none; background: #111; border: 1px solid #333; border-radius: 4px; overflow: hidden; position: relative; transition: border-color 0.2s;">
                          <div
                            style="height: 104px; background: <%= ch.is_live ? `url('/tvsnapshots/${ch.shortname}.jpg') center center / cover no-repeat, ` : '' %>url('<%= CDN_BASE_URL %><%= ch.logo_url || '/images/default_channel_logo.png' %>') center center / contain no-repeat #000; position: relative; overflow: hidden;">
                            <% if (ch.is_18_plus) { %>
                            <div style="position: absolute; top: -5px; left: -5px; right: -5px; bottom: -5px; backdrop-filter: blur(15px); background: rgba(0,0,0,0.3); z-index: 1;"></div>
                            <% } %>
                            <div style="position: relative; z-index: 2; width: 100%; height: 100%;">
                            <div
                              style="position: absolute; top: 5px; right: 5px; background: rgba(0,0,0,0.7); color: #fff; font-size: 11px; padding: 2px 6px; border-radius: 3px;">
                              👁 <%= ch.viewers || 0 %>
                            </div>
                            <% if (ch.is_premium) { %>
                                <div
                                  style="position: absolute; top: 5px; left: 5px; background: #3b9cd9; color: #fff; font-size: 10px; font-weight: bold; padding: 2px 5px; border-radius: 3px; text-transform: uppercase;">
                                  Premium</div>
                            <% } %>
                            <% if (ch.is_live) { %>
                                <div
                                  style="position: absolute; top: <%= ch.is_premium ? '27px' : '5px' %>; left: 5px; background: rgb(229,51,51); color: #fff; font-size: 10px; font-weight: bold; padding: 2px 5px; border-radius: 3px; text-transform: uppercase;">
                                  Live</div>
                            <% } else { %>
                                <div
                                  style="position: absolute; top: <%= ch.is_premium ? '27px' : '5px' %>; left: 5px; background: #555; color: #fff; font-size: 10px; font-weight: bold; padding: 2px 5px; border-radius: 3px; text-transform: uppercase;">
                                  В эфире</div>
                            <% } %>
                            </div>
                          </div>
                          <div style="padding: 10px;">
                            <div
                              style="color: #6fdeee; font-size: 13px; font-weight: bold; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; text-align: left; display: flex; align-items: center;">
                              <span style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= ch.name %></span>
                              <% if (ch.is_verified) { %>
                                <span class="verified_icon" title="Подтвержденный канал" style="flex-shrink: 0; margin-left: 5px;"></span>
                              <% } %>
                            </div>
                            <div
                              style="color: #aaa; font-size: 11px; line-height: 1.3; height: 28px; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; text-align: left;">
                              <%= ch.is_live ? (ch.live_title || ('Передача от ' + formatDate(ch.live_started_at || new Date(), userTimezone, 'DD.MM.YYYY HH:mm'))) : 'Передача от ' + formatDate(ch.updated_at || new Date(), userTimezone, 'DD.MM.YYYY') %>
                            </div>
                          </div>
                        </a>
                        <% }) %>
                          <% } %>
                </div>

                <% if (popularChannels.length> 0) { %>
                  <button id="scrollRight"
                    style="position: absolute; right: -40px; top: 50%; transform: translateY(-50%); width: 30px; height: 30px; background: transparent; border: none; color: #555; font-size: 30px; cursor: pointer; transition: color 0.2s;">&gt;</button>
                  <% } %>
          </div>

          <script>
            document.getElementById('scrollLeft').addEventListener('click', function (e) {
              e.preventDefault();
              document.getElementById('channelsContainer').scrollBy({ left: -203, behavior: 'smooth' });
            });
            document.getElementById('scrollRight').addEventListener('click', function (e) {
              e.preventDefault();
              document.getElementById('channelsContainer').scrollBy({ left: 203, behavior: 'smooth' });
            });
          </script>
        </div>
      </div>


      <!--- News Section for Auth -->
      <div style="background: #1a1a1a; padding: 30px 0; border-top: 1px solid #333; position: relative; z-index: 10;">
        <div style="width: 1000px; margin: 0 auto; position: relative;">
          <div style="text-align: center; margin-bottom: 25px; position: relative;">
            <div style="position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: #333; z-index: 1;">
            </div>
            <span
              style="background: #1a1a1a; padding: 0 20px; color: #fff; font-size: 18px; position: relative; z-index: 2; font-weight: normal;">Последние
              новости</span>
          </div>
          <div style="display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;">
            <% var shortMonths=['Янв', 'Фев' , 'Мар' , 'Апр' , 'Май' , 'Июн' , 'Июл' , 'Авг' , 'Сен' , 'Окт' , 'Ноя'
              , 'Дек' ]; %>
              <% if (latestNews && latestNews.length> 0) { %>
                <% latestNews.slice(0, 3).forEach((item)=> { %>
                  <div
                    style="width: 310px; background: #222; border: 1px solid #333; border-radius: 4px; padding: 15px; box-sizing: border-box;">
                    <div style="color: #aaa; font-size: 11px; margin-bottom: 8px;">
                      <%= ('0' + new Date(item.created_at).getDate()).slice(-2) %>
                        <%= shortMonths[new Date(item.created_at).getMonth()] %>
                    </div>
                    <div style="font-size: 14px; font-weight: bold; margin-bottom: 10px;">
                      <a href="<%= item.is_channel_news ? '/channels/' + item.shortname + '/news/' + item.id : '/ru/news,view,' + item.id %>" style="color: #6fdeee; text-decoration: none;">
                        <%= item.title %>
                      </a>
                    </div>
                    <div
                      style="color: #ccc; font-size: 12px; line-height: 1.4; max-height: 50px; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;">
                      <%= item.announce %>
                    </div>
                  </div>
                  <% }) %>
                    <% } else { %>
                      <div style="color: #777; text-align: center; width: 100%;">Новостей пока нет</div>
                      <% } %>
          </div>
          <div style="text-align: center; margin-top: 20px;">
            <a href="/ru/news" style="color: #6fdeee; text-decoration: none; font-size: 13px;">Все новости →</a>
          </div>
        </div>
      </div>

      <% } %>
        <%- include('partials/footer') %>
