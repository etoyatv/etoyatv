<%- include('partials/header') %>

<div id="content" style="flex: 1 0 auto;">
<div class="left_blocks"> 
<div class="blackbox" style="width: auto;">
<div class="blackbox_tl"></div>
<div class="blackbox_tc"></div>
<div class="blackbox_tr"></div>
<div class="blackbox_cw">
<div class="blackbox_c" style="">
<div class="blackbox_ci"> 
<div style="height:400px; width:1px; margin-left:-1px; float:left;"></div>
<div style="width:100%; float:left;"><div class="block-head-bg"></div>
<div class="block-head">
<div class="block-head-right">
<div class="block-title">Телеканалы <%= searchQuery ? '- Результаты поиска "' + searchQuery + '"' : '' %></div>
</div> 
</div>
<div class="block-head-submenu-bg"></div>
<div class="block-head-submenu">
<div class="block-head-submenu-description">Все телеканалы</div> 
<a href="#list" onclick="submenuClick(this);changeChannelsView(this, 'list');return false;" class="last  pictogramm pictogramm_active"><span class="list"></span></a>
<a href="#grid" onclick="submenuClick(this);changeChannelsView(this, 'grid');return false;" class="  pictogramm "><span class="grid"></span></a>
</div>
<div class="block-content">
<div id="channels_list">
<div class="channels_list">
<% if (channels.length === 0) { %>
    <div style="padding: 20px; text-align: center; color: #888;">Телеканалы не найдены.</div>
<% } else { %>
    <% channels.forEach((channel, idx) => { %>
    <div class="item <%= idx === 0 ? 'first' : '' %> <%= (idx + 1) % 3 === 0 ? 'item_end' : '' %>"> 
    <a href="/<%= channel.shortname %>" class="thumb" style="background: <%= channel.is_live ? `url('/tvsnapshots/${channel.shortname}.jpg') center center / cover no-repeat, ` : '' %>url('<%= CDN_BASE_URL %><%= channel.logo_url || '/images/default_channel_logo.png' %>') center center / contain no-repeat #000; position: relative; overflow: hidden;">
      <% if (channel.is_18_plus) { %>
      <div style="position: absolute; top: -5px; left: -5px; right: -5px; bottom: -5px; backdrop-filter: blur(15px); background: rgba(0,0,0,0.3); z-index: 1;"></div>
      <% } %>
      <span class="border_thumb" style="position: relative; z-index: 2;">
      <% if (channel.is_premium) { %>
        <div class="premium_label"></div>
      <% } %>
      <% if (channel.is_live) { %>
        <div class="live_label"></div>
      <% } else if (channel.autopilot_enabled === 1 || channel.autopilot_enabled) { %>
        <div class="online_label"></div>
      <% } %>
    </span></a>
      <div class="right_panel" style="float: right; width: 52px; text-align: center; margin-left: 10px;">
        <a href="/<%= channel.shortname %>" class="logo" style="display: block; width: 50px; height: 50px;"><img width="50" height="50" src="<%= CDN_BASE_URL %><%= channel.logo_url || '/images/default_channel_logo_50.png'  %>" alt="<%= channel.name %>" style="object-fit: cover; display: block; <%= channel.is_18_plus ? 'filter: blur(4px);' : '' %>"></a>
        <% if (locals.user) { %>
        <div style="background: #111; width: 52px; height: 18px; border-radius: 0 0 3px 3px; display: flex; align-items: center; justify-content: center; gap: 3px;">
          <span id="fans_count_<%= channel.id %>" style="color:#fff; font-size:10px; font-weight:bold; line-height: 16px;"><%= channel.fans_count || 0 %></span>
          <a href="#" onclick="toggleFavorite('<%= channel.id %>'); return false;" style="display: block; width: 16px; height: 16px;"><span class="block-head-icon-heart heart-btn <%= channel.is_fan ? 'active' : '' %>" id="fan_icon_<%= channel.id %>"></span></a>
        </div>
        <% } %>
      </div>
    <div class="info"> 
    <div class="grid_title">Телеканал: <a href="/<%= channel.shortname %>"><%= channel.name %></a><% if (channel.is_verified) { %><span class="verified_icon" title="Подтвержденный канал"></span><% } %><% if(channel.is_18_plus) { %> <span class="label_18" style="display:inline-block; vertical-align:middle; margin-left:5px; margin-top:0; float:none;"></span><% } %></div> 
    <div class="list_title">Телеканал: <a href="/<%= channel.shortname %>"><%= channel.name %></a><% if (channel.is_verified) { %><span class="verified_icon" title="Подтвержденный канал"></span><% } %><% if(channel.is_18_plus) { %> <span class="label_18" style="display:inline-block; vertical-align:middle; margin-left:5px; margin-top:0; float:none;"></span><% } %></div> 

    <div class="description darkgrey" style="white-space: pre-wrap; overflow-wrap: break-word; word-wrap: break-word; word-break: break-word;"><%= channel.description || 'Описание телеканала не заполнено' %></div>
    </div>
    <div class="clear_both"></div>
    </div> 
        <% if ((idx + 1) % 3 === 0 && idx !== channels.length - 1) { %>
            <div class="clear_both dottedline breakline" style="height:25px;"></div> 
        <% } %>
    <% }) %>
<% } %>
</div>

<!-- Pager Navigator --> 
<div class="pager">
    <% if (totalPages > 1) { %>
        <% if (currentPage > 1) { %>
            <div style="float:left;">
                <div class="item prev"><a href="/ru/tv,channels?page=<%= currentPage - 1 %><%= searchQuery ? '&q='+searchQuery : '' %>">Предыдущая</a></div>
            </div>
        <% } %>

        <% for(let i=1; i<=totalPages; i++) { %>
            <% if (i === currentPage) { %>
                <div class="item active"><%= i %></div>
            <% } else if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
                <div class="item"><a href="/ru/tv,channels?page=<%= i %><%= searchQuery ? '&q='+searchQuery : '' %>"><%= i %></a></div>
            <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
                <div class="item">...</div>
            <% } %>
        <% } %>

        <% if (currentPage < totalPages) { %>
            <div style="float:right;">
                <div class="item next"><a href="/ru/tv,channels?page=<%= currentPage + 1 %><%= searchQuery ? '&q='+searchQuery : '' %>">Следующая</a></div>
            </div>
        <% } %>
    <% } %>
<div class="clear_both"></div>
</div> 
<!-- Pager Navigator --> 
</div>
</div>
<div class="clear_both"></div></div>
<div class="clear_both"></div>
</div><div class="clear_both"></div>
</div></div>
<div class="blackbox_bl"></div>
<div class="blackbox_bc"></div>
<div class="blackbox_br"></div>
</div>

</div>
<!-- << LEFT COLUMN --> 
<!-- RIGHT COLUMN>> -->
<div class="right_blocks"> 
<div class="blocks"> 
<div class="blackbox" style="width: auto;">
<div class="blackbox_tl"></div>
<div class="blackbox_tc"></div>
<div class="blackbox_tr"></div>
<div class="blackbox_cw">
<div class="blackbox_c" style="">
<div class="blackbox_ci"> 
<div class="block-head-bg"></div>
<div class="block-head">
<div class="block-head-right">
<div class="block-title">Реклама</div>
</div> 
</div>
<div class="block-content">
<% if (adsEnabled && adsConfig['sidebar_320x240'] && adsConfig['sidebar_320x240'].image) { %>
  <div style="width: 320px; display: flex; align-items: center; justify-content: center; margin: 0 auto;">
    <% if (adsConfig['sidebar_320x240'].url) { %>
      <a href="<%= adsConfig['sidebar_320x240'].url %>" target="_blank" style="display: block;">
        <img src="<%= adsConfig['sidebar_320x240'].image %>" style="max-width: 100%;">
      </a>
    <% } else { %>
      <img src="<%= adsConfig['sidebar_320x240'].image %>" style="max-width: 100%;">
    <% } %>
  </div>
<% } else if (!adsEnabled) { %>
  <!-- Ad is disabled -->
<% } else { %>
  <div style="width: 320px; height: 240px; background: #333; display: flex; align-items: center; justify-content: center; color: #777; margin: 0 auto;">Место для рекламы</div>
<% } %>
<div class="clear_both"></div>
</div><div class="clear_both"></div>
</div></div></div>
<div class="blackbox_bl"></div>
<div class="blackbox_bc"></div>
<div class="blackbox_br"></div>
</div>

</div></div>
<!-- << RIGHT COLUMN -->
<div class="clear_both"></div>
</div>

<script>
function submenuClick(el) {
    $('.block-head-submenu .pictogramm').removeClass('pictogramm_active');
    $(el).addClass('pictogramm_active');
}
function changeChannelsView(el, view) {
    if (view === 'grid') {
        $('#channels_list > .channels_list').removeClass('channels_list').addClass('channels_grid');
    } else {
        $('#channels_list > .channels_grid').removeClass('channels_grid').addClass('channels_list');
    }
}

function toggleFavorite(channelId) {
  fetch(`/api/channels/${channelId}/favorite`, { method: 'POST' })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        const icon = document.getElementById('fan_icon_' + channelId);
        if (icon) {
          if (data.isFan) icon.classList.add('active');
          else icon.classList.remove('active');
        }
        const countEl = document.getElementById('fans_count_' + channelId);
        if (countEl) countEl.innerText = data.count;
      } else if (data.error === 'Не авторизован') {
        window.location.href = '/login';
      }
    });
}
</script>

<%- include('partials/footer') %>
