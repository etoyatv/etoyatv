<%- include('../panel_layout', { activeMenu: 'announces', activeSubmenu: '', breadcrumbs: '<a href="/ru/panel,dashboard" style="text-decoration: none; color: #8c989e;">Панель управления</a> &gt; Анонсы', body: `

<div style="background-color: #f7f7f7; background: linear-gradient(to bottom, #fff 0%, #e6e6e6 100%); padding: 10px; border-bottom: 1px solid #ccc; color: #333; margin: -10px -10px 15px -10px; display: flex; align-items: center; border-radius: 4px 4px 0 0;">
    <div style="flex-grow: 1; font-weight: bold; font-size: 14px;">
        <a href="/ru/panel,dashboard" style="margin-right: 15px; color: #888; text-decoration: none;">Панель управления</a>
        <span style="color: #333;">Анонсы</span>
    </div>
</div>
<div class="card">
    <div class="card-title">Управление анонсами</div>
    <div style="font-size: 13px; color: #aaa; margin-bottom: 20px;">
        Создайте анонс будущей передачи. Ваши зрители смогут добавить его в свое "Личное расписание", чтобы получить уведомление перед началом эфира.
    </div>

    <form id="announce-form" onsubmit="createAnnounce(event)" style="background: #2b3135; padding: 20px; border-radius: 4px; border: 1px solid #1a1e20;">
        <input type="hidden" id="channel_id" value="${panelChannel.id}">
        
        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: bold; margin-bottom: 5px; color: #fff;">Название передачи:</label>
            <input type="text" id="announce_title" required style="width: 100%; padding: 8px; background: #1a1e20; border: 1px solid #3a4247; color: #fff; border-radius: 3px;">
        </div>
        
        <div style="margin-bottom: 15px;">
            <label style="display: block; font-weight: bold; margin-bottom: 5px; color: #fff;">Описание:</label>
            <textarea id="announce_desc" rows="4" maxlength="200" style="width: 100%; padding: 8px; background: #1a1e20; border: 1px solid #3a4247; color: #fff; border-radius: 3px; resize: vertical;"></textarea>
        </div>
        
        <div style="margin-bottom: 20px;">
            <label style="display: block; font-weight: bold; margin-bottom: 5px; color: #fff;">Время начала (ваше местное время):</label>
            <input type="datetime-local" id="announce_time" required style="padding: 8px; background: #1a1e20; border: 1px solid #3a4247; color: #fff; border-radius: 3px;">
        </div>
        
        <button type="submit" class="btn-action" style="padding: 10px 20px; font-size: 14px;">Создать анонс</button>
    </form>
</div>

<div class="card" style="margin-top: 20px;">
    <div class="card-title">Существующие анонсы</div>
    <div style="background: #2b3135; padding: 20px; border-radius: 4px; border: 1px solid #1a1e20;">
        ${(locals.programs && programs.length > 0) ? programs.map(p => {
            const d = new Date(p.start_time);
            return `
                <div style="border-bottom: 1px solid #3a4247; padding-bottom: 15px; margin-bottom: 15px;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <div>
                            <div style="color: #6FDEEE; font-weight: bold; font-size: 15px;">${escapeHtml(p.title)}</div>
                            <div style="color: #aaa; font-size: 12px; margin-top: 4px;">
                                Начало: ${d.toLocaleString('ru-RU')}
                            </div>
                            ${p.description ? `<div style="color: #ccc; font-size: 12px; margin-top: 8px; word-wrap: break-word; overflow-wrap: break-word; word-break: break-word;">${escapeHtml(p.description)}</div>` : ''}
                        </div>
                        <div style="display: flex; gap: 10px;">
                            <button data-id="${p.id}" data-title="${escapeHtml(p.title)}" data-desc="${escapeHtml(p.description || '')}" data-time="${p.start_time.toISOString().slice(0, 16)}" onclick="editAnnounce(this)" class="btn-action" style="padding: 5px 10px; font-size: 12px;">Изменить</button>
                            <button onclick="deleteAnnounce(${p.id})" class="btn-action" style="padding: 5px 10px; font-size: 12px;">Удалить</button>
                        </div>
                    </div>
                </div>
            `;
        }).join('') : `
            <div style="color: #aaa;">Нет созданных анонсов.</div>
        `}
    </div>
</div>

<script>
let editingId = null;

function editAnnounce(element) {
    editingId = element.getAttribute('data-id');
    document.getElementById('announce_title').value = element.getAttribute('data-title');
    document.getElementById('announce_desc').value = element.getAttribute('data-desc');
    document.getElementById('announce_time').value = element.getAttribute('data-time');
    document.querySelector('#announce-form button[type="submit"]').textContent = 'Сохранить изменения';
    window.scrollTo(0, 0);
}

async function deleteAnnounce(id) {
    yatvConfirm('Удалить анонс?', async () => {
        try {
            const res = await fetch('/api/programs/' + id, { method: 'DELETE' });
            const data = await res.json();
            if (data.success) {
                window.location.reload();
            } else {
                alert(data.error || 'Ошибка удаления');
            }
        } catch (e) {
            alert('Ошибка сети');
        }
    });
}

async function createAnnounce(e) {
    e.preventDefault();
    const title = document.getElementById('announce_title').value;
    const desc = document.getElementById('announce_desc').value;
    const time = document.getElementById('announce_time').value;
    const channelId = document.getElementById('channel_id').value;
    
    const payload = { channel_id: channelId, title, description: desc, start_time: time };
    const method = editingId ? 'PUT' : 'POST';
    const url = editingId ? '/api/programs/' + editingId : '/api/programs';
    
    try {
        const res = await fetch(url, {
            method: method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (data.success) {
            document.getElementById('announce-form').reset();
            window.location.href = window.location.pathname;
        } else {
            alert(data.error || 'Ошибка');
        }
    } catch(err) {
        alert('Ошибка сети');
    }
}
</script>
` }) %>
