<%- include('../panel_layout', { activeMenu: 'stat', activeSubmenu: 'audience', breadcrumbs: '<a href="/ru/panel,dashboard">Панель управления</a> &gt; Статистика &gt; Аудитория', body: `

<div style="background-color: #f7f7f7; background: linear-gradient(to bottom, #fff 0%, #e6e6e6 100%); padding: 10px; border-bottom: 1px solid #ccc; color: #333; margin: -10px -10px 15px -10px; display: flex; align-items: center; border-radius: 4px 4px 0 0;">
    <div style="flex-grow: 1; font-weight: bold; font-size: 14px;">
        <a href="/ru/panel,dashboard" style="margin-right: 15px; color: #888; text-decoration: none;">Панель управления</a>
        <span style="margin-right: 15px; color: #888;">Статистика</span>
        <span style="color: #333;">Аудитория</span>
    </div>
</div>

<div style="display: flex; gap: 20px;">
    <div style="flex-grow: 1;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <div style="font-size: 18px; color: #fff;">География аудитории</div>
            <div style="font-size: 11px; color: #8c989e; display: flex; align-items: center; gap: 5px;">
                Период: 
                <select id="periodSelect" class="form-control" style="width: auto; padding: 2px 5px;">
                    <option value="24h">За 24 часа</option>
                    <option value="week">За неделю</option>
                    <option value="month">За месяц</option>
                    <option value="year">За год</option>
                    <option value="all">За все время</option>
                </select>
            </div>
        </div>
        
        <div style="border: 1px solid #4a5359; background: #343b40; padding: 15px; display: flex; align-items: center; justify-content: center; height: 300px;">
            <canvas id="audienceChart"></canvas>
        </div>

    </div>
    
    <div style="width: 250px; flex-shrink: 0; display: flex; flex-direction: column; gap: 20px;">
        <div style="background-color: #3a4247; padding: 15px; border-radius: 4px; border: 1px solid #1a1e20;">
            <div style="font-size: 14px; color: #fff; font-weight: bold; margin-bottom: 10px; font-style: italic;">Статистика</div>
            <div style="font-size: 11px; color: #8c989e; line-height: 1.6;">
                Вы можете просматривать статистику посещаемости Вашего телеканала в разрезе стран. Выберите нужный период для отображения графика.
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener("DOMContentLoaded", function() {
    let chartInstance = null;
    let initialContainerHTML = document.getElementById('audienceChart').parentNode.innerHTML;

    function loadData(period) {
        fetch('/api/panel/stat/audience?period=' + period)
            .then(res => res.json())
            .then(data => {
                const parent = document.getElementById('audienceChart') ? document.getElementById('audienceChart').parentNode : document.querySelector('.flex-grow-1 > div:last-child');
                
                if (data.success && data.data && data.data.length > 0) {
                    if (!document.getElementById('audienceChart')) {
                        parent.innerHTML = '<canvas id="audienceChart"></canvas>';
                    }
                    const ctx = document.getElementById('audienceChart').getContext('2d');
                    const labels = data.data.map(d => d.country_code || 'Неизвестно');
                    const values = data.data.map(d => d.views);

                    if (chartInstance) {
                        chartInstance.destroy();
                    }

                    chartInstance = new Chart(ctx, {
                        type: 'doughnut',
                        data: {
                            labels: labels,
                            datasets: [{
                                data: values,
                                backgroundColor: [
                                    '#00a0e3', '#4bc0c0', '#ff6384', '#ffcd56', '#9966ff', '#ff9f40'
                                ],
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { 
                                    position: 'right',
                                    labels: { color: '#8c989e' }
                                }
                            }
                        }
                    });
                } else {
                    if (chartInstance) {
                        chartInstance.destroy();
                        chartInstance = null;
                    }
                    parent.innerHTML = '<div id="audienceChart" style="display:none;"></div><div style="color: #8c989e; font-style: italic;">Данных для отображения пока нет</div>';
                }
            });
    }

    const periodSelect = document.getElementById('periodSelect');
    periodSelect.addEventListener('change', function() {
        loadData(this.value);
    });

    // Initial load
    loadData(periodSelect.value);
});
</script>

` }) %>
