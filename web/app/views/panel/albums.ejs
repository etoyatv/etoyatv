<%- include('../panel_layout', { activeMenu: 'records', activeSubmenu: 'albums', breadcrumbs: '<a href="/ru/panel,dashboard">Панель управления</a> &gt; <a href="/ru/panel,records">Медиа-архив</a> &gt; Альбомы', body: `

<div style="background-color: #f7f7f7; background: linear-gradient(to bottom, #fff 0%, #e6e6e6 100%); padding: 10px; border-bottom: 1px solid #ccc; color: #333; margin: -10px -10px 15px -10px; display: flex; align-items: center; border-radius: 4px 4px 0 0;">
    <div style="flex-grow: 1; font-weight: bold; font-size: 14px;">
        <a href="/ru/panel,dashboard" style="margin-right: 15px; color: #888; text-decoration: none;">Панель управления</a>
        <span style="margin-right: 15px; color: #333;">Медиа-архив</span>
        <a href="/ru/panel,albums,create" style="color: #888; text-decoration: none;">Создать альбом</a>
    </div>
</div>

<div style="text-align: right; margin-bottom: 15px; color: #8c989e; font-size: 13px;">
    Всего альбомов: <strong>${typeof locals !== 'undefined' && locals.panelStats ? locals.panelStats.totalAlbums : albums.length}</strong>
</div>

<form id="bulk-delete-form" action="/ru/panel,albums,bulk_delete" method="POST" onsubmit="event.preventDefault(); const form = this; yatvConfirm('Удалить выбранные альбомы? Это не удалит сами видео.', () => { form.submit(); });"></form>
<div style="margin-bottom: 15px; display: flex; gap: 15px; align-items: center; background-color: #343b40; padding: 10px; border-radius: 4px; border: 1px solid #1a1e20;">
    <label style="color: #fff; cursor: pointer; display: flex; align-items: center; gap: 5px; font-size: 13px;">
        <input type="checkbox" id="select-all" onclick="const c = document.querySelectorAll('.album-checkbox'); c.forEach(cb => cb.checked = this.checked);">
        Выбрать все
    </label>
    <button type="submit" form="bulk-delete-form" class="btn" style="padding: 5px 15px; background: #ff4d4d; border-color: #cc0000; color: white;" id="bulk-delete-btn">Удалить выбранные</button>
</div>

${(albums && albums.length > 0) ? albums.map(album => `
    <div style="display: flex; gap: 20px; margin-bottom: 20px;">
        <div style="width: 20px; padding-top: 10px;"><input type="checkbox" name="album_ids" value="${album.id}" class="album-checkbox" form="bulk-delete-form"></div>
        <div style="flex-grow: 1;">
            <div style="display: flex; gap: 15px; background-color: #343b40; padding: 15px; border-radius: 4px; border: 1px solid #1a1e20;">
                
                <div style="flex-grow: 1; font-size: 12px; line-height: 1.8;">
                    <div style="font-size: 18px; color: #6fdeee; margin-bottom: 10px;">${escapeHtml(album.title)}</div>
                    <span style="color:#8c989e; display:inline-block; width: 120px;">Создан:</span> ${formatDate(album.created_at, userTimezone)}<br>
                    <span style="color:#8c989e; display:inline-block; width: 120px;">Описание:</span> ${escapeHtml(album.description || 'Описание не заполнено')}<br>
                    
                    <div style="margin-top: 15px; display: flex; gap: 10px;">
                        <a href="/ru/panel,albums,edit?id=${album.id}" class="btn" style="display:inline-block; padding: 5px 15px; text-decoration: none;">Редактировать</a>
                        <form action="/ru/panel,albums,delete" method="POST" style="margin: 0; display: inline;" onsubmit="event.preventDefault(); const form = this; yatvConfirm('Удалить альбом? Это не удалит сами видео.', () => { form.submit(); });">
                            <input type="hidden" name="id" value="${album.id}">
                            <button type="submit" class="btn">Удалить</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
`).join('') : `
    <p style="color: #8c989e; text-align: center; margin-top: 50px;">У вас пока нет ни одного альбома. Нажмите «Создать альбом» сверху.</p>
`}

${(typeof totalPages !== 'undefined' && totalPages > 1) ? 
    '<div style="margin-top: 20px; text-align: center;">' +
        (currentPage > 1 ? '<a href="?page=' + (currentPage - 1) + '" class="btn" style="padding: 5px 15px; margin-right: 5px; text-decoration: none;">&laquo; Назад</a>' : '') +
        '<span style="color: #8c989e; margin: 0 10px;">Страница ' + currentPage + ' из ' + totalPages + '</span>' +
        (currentPage < totalPages ? '<a href="?page=' + (currentPage + 1) + '" class="btn" style="padding: 5px 15px; margin-left: 5px; text-decoration: none;">Вперед &raquo;</a>' : '') +
    '</div>'
: ''}

` }) %>
