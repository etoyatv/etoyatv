<%- include('partials/header') %>
<script src="https://js.hcaptcha.com/1/api.js" async defer></script>

<div id="content">
<div class="left_blocks" style="width: 500px; margin: 50px auto; float: none;">
<div class="blackbox" id="login_block" style="width: auto;">
<div class="blackbox_tl"></div>
<div class="blackbox_tc"></div>
<div class="blackbox_tr"></div>
<div class="blackbox_cw">
<div class="blackbox_c" style="">
<div class="blackbox_ci"> 
<div class="block-head-bg"></div>
<div class="block-head">
<div class="block-head-right">
<div class="block-title">Вход</div>
</div>
</div>
<div class="block-content">
<% if (typeof error !== 'undefined' && error) { %>
  <div style="color: #ff6666; margin-bottom: 15px; font-weight: bold; text-align: center;"><%= error %></div>
  <% if (typeof unverifiedUser !== 'undefined') { %>
    <form action="/register/resend" method="post" style="display: flex; justify-content: center; margin-bottom: 15px;">
      <input type="hidden" name="username" value="<%= unverifiedUser %>">
      <button type="submit" style="background: #333; border: 1px solid #555; padding: 5px 15px; color: #fff; cursor: pointer; border-radius: 3px;">Отправить письмо повторно</button>
    </form>
  <% } %>
<% } %>
<% if (typeof success !== 'undefined' && success) { %>
  <div style="color: #6fdeee; margin-bottom: 15px; font-weight: bold; text-align: center;"><%= success %></div>
<% } %>
<form action="/login" method="post" style="padding: 20px 0 20px 10px;">

  <div class="forms-item">
    <div class="label">Логин:<span class="blue">*</span></div>
    <input type="text" name="username" class="input-text" required>
    <div class="clear_both"></div>
  </div>
  <div class="forms-item">
    <div class="label">Пароль:<span class="blue">*</span></div>
    <input type="password" name="password" class="input-text" required>
    <div class="clear_both"></div>
  </div>
  <div class="forms-item" style="margin-bottom: 15px;">
    <div class="label"></div>
    <div class="h-captcha" data-sitekey="<%= HCAPTCHA_SITEKEY %>" data-theme="dark"></div>
    <div class="clear_both"></div>
  </div>
  <div class="forms-item" style="margin-top:20px;">
    <div class="label"></div>
    <div style="float:left;">
      <button type="submit" style="background: #333; border: 1px solid #555; padding: 5px 15px; color: #fff; font-weight: bold; cursor: pointer; border-radius: 3px;">Войти</button>
      <a href="/forgot-password" style="margin-left: 15px; color: #6fdeee; text-decoration: none; font-size: 12px;">Забыли пароль?</a>
    </div>
    <div class="clear_both"></div>
  </div>
</form>
</div>
<div class="clear_both"></div>
</div>
</div>
</div>
<div class="blackbox_bl"></div>
<div class="blackbox_bc"></div>
<div class="blackbox_br"></div>
</div>
</div>
<div class="clear_both"></div>
</div>

<%- include('partials/footer') %>
