<%- include('partials/header') %>

  <div id="content">
    <!-- LEFT COLUMN>> -->
    <div class="left_blocks">

      <% if (user && user.username===profileUser.username && pendingRequests && pendingRequests.length> 0) { %>
        <!-- PENDING FRIEND REQUESTS>> -->
        <div class="block_item">
          <div class="blackbox" style="width: auto;">
            <div class="blackbox_tl"></div>
            <div class="blackbox_tc"></div>
            <div class="blackbox_tr"></div>
            <div class="blackbox_cw">
              <div class="blackbox_c" style="">
                <div class="blackbox_ci">
                  <div class="block-head-bg"></div>
                  <div class="block-head">
                    <div class="block-head-right">
                      <div class="block-title">Запросы в друзья (<span class="white"><%= pendingRequests.length %></span>)</div>
                    </div>
                  </div>
                  <div class="block-content" style="padding: 10px;">
                    <ul style="list-style: none; padding: 0; margin: 0;">
                      <% pendingRequests.forEach(function(reqUser, index) { %>
                        <li class="incoming-req-item"
                          style="margin-bottom: 10px; display: <%= index >= 5 ? 'none' : 'flex' %>; align-items: center; justify-content: space-between;">
                          <span style="font-size: 14px; color: #fff;">
                            <a href="/ru/account,userinfo/?username=<%= encodeURIComponent(reqUser.username) %>"
                              style="color: #6fdeee; font-weight: bold; text-decoration: none;">
                              <%= reqUser.username %>
                            </a> хочет добавить вас в друзья
                          </span>
                          <div style="margin-top: 5px;">
                            <a href="/friends/accept?username=<%= encodeURIComponent(reqUser.username) %>"
                              style="background: #39b54a; color: white; padding: 3px 8px; text-decoration: none; border-radius: 3px; font-size: 11px; margin-right: 5px;">Принять</a>
                            <a href="/friends/reject?username=<%= encodeURIComponent(reqUser.username) %>"
                              style="background: #c0392b; color: white; padding: 3px 8px; text-decoration: none; border-radius: 3px; font-size: 11px;">Отклонить</a>
                          </div>
                        </li>
                        <% }) %>
                    </ul>
                    <% if (pendingRequests.length > 5) { %>
                      <div class="show-all-incoming" style="text-align: center; margin-top: 10px;">
                        <a href="#" onclick="$('.incoming-req-item').css('display', 'flex'); $('.show-all-incoming').hide(); return false;" style="color: #6fdeee; text-decoration: none; font-size: 12px; font-weight: bold;">Показать все (<%= pendingRequests.length %>)</a>
                      </div>
                    <% } %>
                    <div class="clear_both"></div>
                  </div>
                  <div class="clear_both"></div>
                </div>
                <div class="clear_both"></div>
              </div>
            </div>
            <div class="blackbox_bl"></div>
            <div class="blackbox_bc"></div>
            <div class="blackbox_br"></div>
          </div>
        </div>
        <!-- << PENDING FRIEND REQUESTS -->
        <% } %>

      <% if (user && user.username===profileUser.username && typeof pendingOutgoingRequests !== 'undefined' && pendingOutgoingRequests.length> 0) { %>
        <!-- OUTGOING FRIEND REQUESTS>> -->
        <div class="block_item">
          <div class="blackbox" style="width: auto;">
            <div class="blackbox_tl"></div>
            <div class="blackbox_tc"></div>
            <div class="blackbox_tr"></div>
            <div class="blackbox_cw">
              <div class="blackbox_c" style="">
                <div class="blackbox_ci">
                  <div class="block-head-bg"></div>
                  <div class="block-head">
                    <div class="block-head-right">
                      <div class="block-title">Исходящие заявки (<span class="white"><%= pendingOutgoingRequests.length %></span>)</div>
                    </div>
                  </div>
                  <div class="block-content" style="padding: 10px;">
                    <ul style="list-style: none; padding: 0; margin: 0;">
                      <% pendingOutgoingRequests.forEach(function(reqUser, index) { %>
                        <li class="outgoing-req-item"
                          style="margin-bottom: 10px; display: <%= index >= 5 ? 'none' : 'flex' %>; align-items: center; justify-content: space-between;">
                          <span style="font-size: 14px; color: #fff;">
                            Ожидает ответа: <a href="/ru/account,userinfo/?username=<%= encodeURIComponent(reqUser.username) %>"
                              style="color: #ffcc00; font-weight: bold; text-decoration: none;">
                              <%= reqUser.username %>
                            </a>
                          </span>
                          <div style="margin-top: 5px;">
                            <a href="/friends/remove?username=<%= encodeURIComponent(reqUser.username) %>"
                              style="background: #c0392b; color: white; padding: 3px 8px; text-decoration: none; border-radius: 3px; font-size: 11px;">Отменить запрос</a>
                          </div>
                        </li>
                        <% }) %>
                    </ul>
                    <% if (pendingOutgoingRequests.length > 5) { %>
                      <div class="show-all-outgoing" style="text-align: center; margin-top: 10px;">
                        <a href="#" onclick="$('.outgoing-req-item').css('display', 'flex'); $('.show-all-outgoing').hide(); return false;" style="color: #ffcc00; text-decoration: none; font-size: 12px; font-weight: bold;">Показать все (<%= pendingOutgoingRequests.length %>)</a>
                      </div>
                    <% } %>
                    <div class="clear_both"></div>
                  </div>
                  <div class="clear_both"></div>
                </div>
                <div class="clear_both"></div>
              </div>
            </div>
            <div class="blackbox_bl"></div>
            <div class="blackbox_bc"></div>
            <div class="blackbox_br"></div>
          </div>
        </div>
        <!-- << OUTGOING FRIEND REQUESTS -->
      <% } %>

          <!-- PROGRAMMS LIST>> -->

          <div class="block_item">
            <div class="blackbox" style="width: auto;">
              <div class="blackbox_tl"></div>
              <div class="blackbox_tc"></div>
              <div class="blackbox_tr"></div>
              <div class="blackbox_cw">
                <div class="blackbox_c" style="">
                  <div class="blackbox_ci">
                    <div class="block-head-bg"></div>
                    <div class="block-head">
                      <div class="block-head-right">
                        <div class="block-title">Личное расписание (<a href="/ru/account,programs?username=<%= encodeURIComponent(profileUser.username) %>" class="darkblue"><%= personalSchedulesTotal %></a>)</div>
                        <div class="block-buttons">
                          <a href="/ru/account,programs?username=<%= encodeURIComponent(profileUser.username) %>" class="block-buttons-bg-last"><span class="block-head-icon-archive"></span></a>
                        </div>
                      </div>
                    </div>
                    <div class="block-content">
                      <div id="translations_list" style="padding: 0;">
                        <% if (locals.personalSchedules && personalSchedules.length > 0) { %>
                          <% personalSchedules.forEach(function(ps, index) { %>
                            <div class="item <%= index === 0 ? 'first' : '' %> <%= index === personalSchedules.length - 1 ? 'last item_end' : '' %>" style="padding: 8px 0; border-bottom: 1px dotted #444; position: relative; clear: both; overflow: hidden;">
                              <div class="date" style="float: left; width: 70px; text-align: center; margin-right: 15px;">
                                <% const d = new Date(ps.start_time); %>
                                <div class="time" style="font-size: 16px; font-weight: bold; color: #c0c0b2; line-height: 1.2;"><%= ('0' + d.getHours()).slice(-2) + ':' + ('0' + d.getMinutes()).slice(-2) %></div>
                                <div class="day" style="font-size: 11px; color: #777; margin-top: 4px; line-height: 1.2;"><%= d.getDate() %> <%= ['Января','Февраля','Марта','Апреля','Мая','Июня','Июля','Августа','Сентября','Октября','Ноября','Декабря'][d.getMonth()] %></div>
                              </div>
                              <div class="logotype" style="float: left; width: 100px; height: 100px; margin-right: 15px;">
                                <a href="/<%= ps.shortname %>" class="logo" style="background: #000 url('<%= CDN_BASE_URL %><%= ps.logo_url || '/images/default_channel_logo.png' %>') no-repeat center center; background-size: contain; display: block; width: 100%; height: 100%; <%= typeof ps.is_18_plus !== 'undefined' && ps.is_18_plus ? 'filter: blur(4px);' : '' %>">
                                  <span class="border_logo"></span>
                                </a>
                              </div>
                              <div class="info" style="overflow: hidden; padding-left: 10px; padding-top: 2px;">
                                <div class="title" style="margin-bottom: 8px;">
                                  <a href="/<%= ps.shortname %>" style="color: #6FDEEE; font-size: 16px; text-decoration: none;"><%= ps.title %></a>
                                </div>
                                <div class="channel" style="font-size: 12px; color: #8c989e; margin-bottom: 8px;">
                                  Телеканал: <a href="/<%= ps.shortname %>" style="color: #6FDEEE; text-decoration: none;"><%= ps.channel_name %></a>
                                </div>
                                <div class="description" style="font-size: 12px; color: #555; margin-bottom: 15px; overflow-wrap: break-word; word-wrap: break-word; word-break: break-word;">
                                  <%= ps.description || 'Описание передачи не заполнено' %>
                                </div>
                                <div class="likes-badge" style="position: absolute; right: 0; top: 15px;">
                                  <span id="program_bookmarks_count_<%= ps.id %>"
                                    style="color:#fff; font-size:10px; font-weight:bold; line-height: 18px; padding-top: 1px;">
                                    <%= ps.bookmarks_count || 0 %>
                                  </span>
                                  <% if (locals.user) { %>
                                    <a href="#" onclick="toggleBookmark(<%= ps.id %>); return false;"
                                      style="display: flex; align-items: center; justify-content: center; width: 16px; height: 16px; text-decoration: none;"><span
                                        class="block-head-icon-heart heart-btn <%= (typeof ps.is_bookmarked !== 'undefined' ? ps.is_bookmarked : false) ? 'active' : '' %>"
                                        id="program_bookmark_icon_<%= ps.id %>"
                                        style="display: block; width: 16px; height: 16px; margin: 0; padding: 0;"></span></a>
                                  <% } else { %>
                                    <a href="/login"
                                      style="display: flex; align-items: center; justify-content: center; width: 16px; height: 16px; text-decoration: none;"><span
                                        class="block-head-icon-heart heart-btn"
                                        style="display: block; width: 16px; height: 16px; margin: 0; padding: 0;"></span></a>
                                  <% } %>
                                </div>
                              </div>
                            </div>
                          <% }); %>
                        <% } else { %>
                          <div style="color: #c0c0b2;">Список пуст</div>
                        <% } %>
                      </div>
                      <div class="clear_both"></div>
                    </div>
                    <div class="clear_both"></div>
                  </div>
                  <div class="clear_both"></div>
                </div>
              </div>
              <div class="blackbox_bl"></div>
              <div class="blackbox_bc"></div>
              <div class="blackbox_br"></div>
            </div>
          </div>
          <!-- << PROGRAMMS LIST -->

          <!-- FAVORITES RECORDS>> -->
          <div class="block_item">
            <div class="blackbox" style="width: auto;">
              <div class="blackbox_tl"></div>
              <div class="blackbox_tc"></div>
              <div class="blackbox_tr"></div>
              <div class="blackbox_cw">
                <div class="blackbox_c" style="">
                  <div class="blackbox_ci">
                    <div class="block-head-bg"></div>
                    <div class="block-head">
                      <div class="block-head-right">
                        <div class="block-title">Избранные записи (<a href="/ru/account,favrecords?username=<%= encodeURIComponent(profileUser.username) %>" class="darkblue"><%= favoriteRecordsTotal %></a>)</div>
                        <div class="block-buttons">
                          <a href="/ru/account,favrecords?username=<%= encodeURIComponent(profileUser.username) %>"
                            class="block-buttons-bg-last"><span class="block-head-icon-archive"></span></a>
                        </div>
                      </div>
                    </div>
                    <div class="block-content">
                      <div class="records_list" style="padding: 10px;">
                        <% if (favoriteRecords && favoriteRecords.length> 0) { %>
                          <% favoriteRecords.forEach(function(rec, index) { %>
                            <div
                              class="item <%= index === 0 ? 'first' : '' %> <%= index === favoriteRecords.length - 1 ? 'last item_end' : '' %>">
                              <div class="record_item" style="position: relative;" style="position: relative;">
                                <a href="/ru/tv,viewrecord,<%= rec.id %>" class="thumb"
                                  style="background: #000 url('<%= CDN_BASE_URL %><%= rec.thumbnail_url || '/images/default_record_thumb.png' %>') no-repeat center center; background-size: cover; position: relative; overflow: hidden;">
                                  <% if (rec.is_18_plus) { %>
                                  <div style="position: absolute; top: -5px; left: -5px; right: -5px; bottom: -5px; backdrop-filter: blur(5px); background: rgba(0,0,0,0.1); z-index: 1;"></div>
                                  <% } %>
                                  <span class="border_thumb" style="position: relative; z-index: 2;">
                                    <div class="record_time">
                                      <%= ('0' + Math.floor(rec.duration / 3600)).slice(-2) %>:<%= ('0' +
                                          Math.floor((rec.duration % 3600) / 60)).slice(-2) %>:<%= ('0' + (rec.duration
                                            % 60)).slice(-2) %>
                                    </div>
                                  </span>
                                </a>
                                <div class="info">
                                  <div class="title"><a href="/ru/tv,viewrecord,<%= rec.id %>">
                                      <%= rec.title %>
                                    </a><% if(rec.is_18_plus) { %> <span class="label_18" style="display:inline-block; vertical-align:middle; margin-left:5px; margin-top:0; float:none;"></span><% } %></div>
                                  <div class="channel"><span class="label">Телеканал:</span> <a
                                      href="/<%= rec.shortname %>">
                                      <%= rec.channel_name %>
                                    </a></div>
                                  <div class="date"><span class="label">Дата:</span> <span class="white">
                                      <%= ('0' + new Date(rec.created_at).getDate()).slice(-2) %>.<%= ('0' + (new
                                          Date(rec.created_at).getMonth() + 1)).slice(-2) %>.<%= new
                                            Date(rec.created_at).getFullYear() %>
                                    </span></div>
                                  <div class="views"><span class="label">Просмотров:</span> <span class="white">
                                      <%= rec.views || 0 %>
                                    </span></div>
                                </div>
                                <div style="position: absolute; right: 0; top: 0;">
                                  <% if (locals.user) { %>
                                  <div class="likes-badge">
                                    <span id="record_fans_count_<%= rec.id %>" style="color:#fff; font-size:10px; font-weight:bold; line-height: 18px; padding-top: 1px;"><%= rec.fans_count || 0 %></span>
                                    <a href="#" onclick="toggleFavoriteRecord('<%= rec.id %>'); return false;" style="display: flex; align-items: center; justify-content: center; width: 16px; height: 16px; text-decoration: none;"><span class="block-head-icon-heart heart-btn <%= rec.is_fan ? 'active' : '' %>" id="record_fan_icon_<%= rec.id %>" style="display: block; width: 16px; height: 16px; margin: 0; padding: 0;"></span></a>
                                  </div>
                                  <% } %>
                                </div>

                              </div>
                              <div class="clear_both"></div>
                            </div>
                            <% }); %>
                              <% } else { %>
                                <p style="color: #c0c0b2;">Нет записей</p>
                                <% } %>
                      </div>
                    </div>
                    <div class="clear_both"></div>
                  </div>
                  <div class="clear_both"></div>
                </div>
              </div>
              <div class="blackbox_bl"></div>
              <div class="blackbox_bc"></div>
              <div class="blackbox_br"></div>
            </div>
          </div>
          <!-- << FAVORITES RECORDS -->

          <!-- FAVORITES CHANNEL>> -->
          <div class="block_item">
            <div class="blackbox" style="width: auto;">
              <div class="blackbox_tl"></div>
              <div class="blackbox_tc"></div>
              <div class="blackbox_tr"></div>
              <div class="blackbox_cw">
                <div class="blackbox_c" style="">
                  <div class="blackbox_ci">
                    <div class="block-head-bg"></div>
                    <div class="block-head">
                      <div class="block-head-right">
                        <div class="block-title">Избранные телеканалы (<a href="/ru/account,favchannels?username=<%= encodeURIComponent(profileUser.username) %>" class="darkblue"><%= favoriteChannelsTotal %></a>)</div>
                        <div class="block-buttons">
                          <a href="/ru/account,favchannels?username=<%= encodeURIComponent(profileUser.username) %>"
                            title="Все избранные телеканалы" class="block-buttons-bg-last"><span
                              class="block-head-icon-archive"></span></a>
                        </div>
                      </div>
                    </div>
                    <div class="block-content">
                      <div id="channels_list">
                        <div class="channels_list">
                          <% if (favoriteChannels.length> 0) { %>
                            <% favoriteChannels.forEach((chan, index)=> { %>
                              <div
                                class="item <%= index === 0 ? 'first' : '' %> <%= index === favoriteChannels.length - 1 ? 'last item_end' : '' %>">
                                <a href="/<%= chan.shortname %>" class="thumb"
                                  style="background: <%= chan.is_live ? `url('/tvsnapshots/${chan.shortname}.jpg') center center / cover no-repeat, ` : '' %>url('<%= CDN_BASE_URL %><%= chan.logo_url || '/images/default_channel_logo.png' %>') center center / contain no-repeat #000; position: relative; overflow: hidden;">
                                  <% if (chan.is_18_plus) { %>
                                  <div style="position: absolute; top: -5px; left: -5px; right: -5px; bottom: -5px; backdrop-filter: blur(15px); background: rgba(0,0,0,0.3); z-index: 1;"></div>
                                  <% } %>
                                  <span class="border_thumb" style="position: relative; z-index: 2;">
                                    <% if (chan.is_premium) { %>
                                      <div class="premium_label"></div>
                                    <% } %>
                                    <% if (chan.is_live) { %>
                                      <div class="live_label"></div>
                                    <% } else if (chan.autopilot_enabled === 1 || chan.autopilot_enabled) { %>
                                      <div class="online_label"></div>
                                    <% } %>
                                  </span></a>
                                <div class="right_panel" style="float: right; width: 52px; text-align: center; margin-left: 10px;">
                                    <a href="/<%= chan.shortname %>" class="logo" style="display: block; width: 50px; height: 50px;"><img width="50" height="50"
                                        src="<%= CDN_BASE_URL %><%= chan.logo_url || '/images/default_channel_logo.png'  %>"
                                        alt="<%= chan.name %>" style="object-fit: <%= chan.logo_fit === 'contain' ? 'contain' : 'cover' %>; <%= chan.logo_fit === 'contain' ? 'background: #000;' : '' %> display: block; <%= chan.is_18_plus ? 'filter: blur(4px);' : '' %>"></a>
                                    <% if (locals.user) { %>
                                    <div class="likes-badge channel-badge">
                                      <span id="fans_count_<%= chan.id %>" style="color:#fff; font-size:10px; font-weight:bold; line-height: 16px;">
                                        <%= chan.fans_count || 0 %>
                                      </span>
                                      <a href="#" onclick="toggleFavorite('<%= chan.id %>'); return false;" style="display: block; width: 16px; height: 16px;"><span class="block-head-icon-heart heart-btn <%= chan.is_fan ? 'active' : '' %>" id="fan_icon_<%= chan.id %>"></span></a>
                                    </div>
                                    <% } %>
                                  </div>
                                <div class="info">
                                  <div class="grid_title">Телеканал: <a href="/<%= chan.shortname %>">
                                      <%= chan.name.length > 15 ? chan.name.substring(0, 15) + '...' : chan.name %>
                                    </a><% if (chan.is_verified) { %><span class="verified_icon <%= chan.is_premium ? 'blue' : '' %>" title="<%= chan.is_premium ? 'Премиум канал' : 'Подтвержденный канал' %>"></span><% } %><% if(chan.is_18_plus) { %> <span class="label_18" style="display:inline-block; vertical-align:middle; margin-left:5px; margin-top:0; float:none;"></span><% } %></div>
                                  <div class="list_title">Телеканал: <a href="/<%= chan.shortname %>">
                                      <%= chan.name %>
                                    </a><% if (chan.is_verified) { %><span class="verified_icon <%= chan.is_premium ? 'blue' : '' %>" title="<%= chan.is_premium ? 'Премиум канал' : 'Подтвержденный канал' %>"></span><% } %><% if(chan.is_18_plus) { %> <span class="label_18" style="display:inline-block; vertical-align:middle; margin-left:5px; margin-top:0; float:none;"></span><% } %></div>
                                  <div class="description darkgrey" style="white-space: pre-wrap; overflow-wrap: break-word; word-wrap: break-word; word-break: break-word;"><%= chan.description || 'Описание отсутствует.' %></div>
                                </div>
                                <div class="clear_both"></div>
                              </div>
                              <% }) %>
                                <% } else { %>
                                  <div style="padding: 10px; color: #c0c0b2;">Нет избранных каналов</div>
                                  <% } %>
                        </div>
                      </div>
                      <div class="clear_both"></div>
                    </div>
                    <div class="clear_both"></div>
                  </div>
                  <div class="clear_both"></div>
                </div>
              </div>
              <div class="blackbox_bl"></div>
              <div class="blackbox_bc"></div>
              <div class="blackbox_br"></div>
            </div>
          </div>
          <!-- << FAVORITES CHANNEL -->

          <!-- COMMENTS LIST>> -->
          <div class="block_item">
            <div class="blackbox" style="width: auto;">
              <div class="blackbox_tl"></div>
              <div class="blackbox_tc"></div>
              <div class="blackbox_tr"></div>
              <div class="blackbox_cw">
                <div class="blackbox_c" style="">
                  <div class="blackbox_ci">
                    <div class="block-head-bg"></div>
                    <div class="block-head">
                      <div class="block-head-right">
                        <div class="block-title">Комментарии <%- `(<span class="blue" id="comments_count">${typeof totalComments !== 'undefined' ? totalComments : 0}</span>)` %></div>
                        <div class="block-buttons"></div>
                      </div>
                    </div>
                    <div class="block-content">
                      <div id="comments_list">
                        <div id="comment_add_form" style="display: block;">
                          <% if (typeof user !=='undefined' && user) { %>
                            <form action="#" onsubmit="addProfileComment(event, '<%= profileUser.username %>'); return false;">
                              <textarea class="input-textarea" id="profileCommentText" name="text" cols="10" rows="10"
                                style="width: 540px; height: 50px; font-family: Arial, Helvetica, sans-serif; font-size: 12px; padding: 5px;"
                                maxlength="300" required></textarea>

                              <div class="button button_grey" style="width: 120px; margin-top: 10px;">
                                <div class="button_left"></div>
                                <input type="submit" class="button_right" style="width: 108px" value="Отправить">
                              </div>
                              <div id="comment_form_error"></div>
                              <div class="clear_both"></div>
                            </form>
                          <% } else { %>
                            <p style="color: #c0c0b2; margin-bottom: 20px;">Пожалуйста, <a href="/login" style="color: #6fdeee;">войдите</a> или <a href="/register" style="color: #6fdeee;">зарегистрируйтесь</a>, чтобы оставить комментарий.</p>
                          <% } %>
                        </div>
                        <div class="comments" id="profile_comments_container" style="margin-top: 15px;">
                          <%- include('partials/profile_comments_list') %>
                        </div>
                      </div>
                    </div>
                    <div class="clear_both"></div>
                  </div>
                  <div class="clear_both"></div>
                </div>
              </div>
              <div class="blackbox_bl"></div>
              <div class="blackbox_bc"></div>
              <div class="blackbox_br"></div>
            </div>
          </div>
          <!-- << COMMENTS LIST -->

    </div>
    <!-- << LEFT COLUMN -->
    <!-- RIGHT COLUMN>> -->
    <div class="right_blocks">
      <%- include('partials/admin_tools') %>
      <!-- USER INFO>> -->
      <div class="blocks">
        <div class="blackbox" style="width: auto;">
          <div class="blackbox_tl"></div>
          <div class="blackbox_tc"></div>
          <div class="blackbox_tr"></div>
          <div class="blackbox_cw">
            <div class="blackbox_c" style="">
              <div class="blackbox_ci">
                <div class="block-head-bg"></div>
                <div class="block-head">
