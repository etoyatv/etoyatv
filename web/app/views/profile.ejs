  <script>
    function toggleFavorite(channelId) {
      fetch(`/api/channels/${channelId}/favorite`, { method: 'POST' })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            const icon = document.getElementById('fan_icon_' + channelId);
            if (icon) {
              if (data.isFan) icon.classList.add('active');
              else icon.classList.remove('active');
            }
            const countEl = document.getElementById('fans_count_' + channelId);
            if (countEl) countEl.innerText = data.count;
          } else if (data.error === 'Не авторизован') {
            window.location.href = '/login';
          }
        });
    }
  </script>

  
<script>
window.toggleFavoriteRecord = async function(recordId) {
  try {
    const res = await fetch(`/api/records/${recordId}/favorite`, { method: 'POST' });
    const data = await res.json();
    if (data.success) {
      const countEl = document.getElementById('record_fans_count_' + recordId);
      const iconEl = document.getElementById('record_fan_icon_' + recordId);
      if (countEl) countEl.innerText = data.count;
      if (iconEl) {
        if (data.isFan) {
          iconEl.classList.add('active');
        } else {
          iconEl.classList.remove('active');
        }
      }
    } else {
      alert(data.error || 'Ошибка');
    }
  } catch (e) {
    alert('Ошибка соединения');
  }
};

window.toggleBookmark = async function(programId) {
  try {
    const res = await fetch(`/api/programs/${programId}/bookmark`, { method: 'POST' });
    const data = await res.json();
    if (data.success) {
      const countEl = document.getElementById('program_bookmarks_count_' + programId);
      const iconEl = document.getElementById('program_bookmark_icon_' + programId);
      if (countEl) {
        let cur = parseInt(countEl.innerText) || 0;
        countEl.innerText = data.action === 'added' ? cur + 1 : Math.max(0, cur - 1);
      }
      if (iconEl) {
        if (data.action === 'added') {
          iconEl.classList.add('active');
        } else {
          iconEl.classList.remove('active');
        }
      }
    } else {
      alert(data.error || 'Ошибка');
    }
  } catch (e) {
    alert('Ошибка сети');
  }
};

window.loadProfileComments = async function(event, username, page) {
  if (event) event.preventDefault();
  try {
    const res = await fetch(`/api/profiles/${encodeURIComponent(username)}/comments_html?cpage=${page}`);
    const html = await res.text();
    document.getElementById('profile_comments_container').innerHTML = html;
  } catch (e) {
    console.error('Error loading comments', e);
  }
};

window.refreshProfileCommentsCount = async function(username) {
  try {
    const res = await fetch(`/api/profiles/${encodeURIComponent(username)}/comments_count`);
    const data = await res.json();
    if (data.success && document.getElementById('comments_count')) {
      document.getElementById('comments_count').innerText = data.count;
    }
  } catch (e) {
    console.error('Error refreshing comment count', e);
  }
};

window.addProfileComment = async function(event, username) {
  event.preventDefault();
  const textInput = document.getElementById('profileCommentText');
  const text = textInput.value;
  if (!text.trim()) return;
  try {
    const res = await fetch(`/api/profiles/${encodeURIComponent(username)}/comment`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text })
    });
    const data = await res.json();
    if (data.success) {
      textInput.value = '';
      window.loadProfileComments(null, username, 1);
      window.refreshProfileCommentsCount(username);
    } else {
      alert(data.error || 'Ошибка при добавлении комментария');
    }
  } catch (e) {
    alert('Ошибка соединения');
  }
};

window.deleteProfileComment = async function(username, commentId) {
  yatvConfirm('Вы уверены, что хотите удалить комментарий?', async () => {
    try {
      const res = await fetch(`/api/profiles/${encodeURIComponent(username)}/comment/${commentId}`, {
        method: 'DELETE'
      });
      const data = await res.json();
      if (data.success) {
        window.loadProfileComments(null, username, 1);
        window.refreshProfileCommentsCount(username);
      } else {
        alert(data.error || 'Ошибка при удалении комментария');
      }
    } catch (e) {
      alert('Ошибка соединения');
    }
  });
};
</script>

