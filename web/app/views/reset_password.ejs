<%- include('partials/header') %>

<div id="content">
<div class="left_blocks" style="width: 500px; margin: 50px auto; float: none;">
<div class="blackbox" id="reset_block" style="width: auto;">
<div class="blackbox_tl"></div>
<div class="blackbox_tc"></div>
<div class="blackbox_tr"></div>
<div class="blackbox_cw">
<div class="blackbox_c" style="">
<div class="blackbox_ci"> 
<div class="block-head-bg"></div>
<div class="block-head">
<div class="block-head-right">
<div class="block-title">Смена пароля</div>
</div>
</div>
<div class="block-content">
<form action="/reset-password" method="post" style="padding: 20px 0 20px 10px;">
<% if (typeof error !== 'undefined' && error) { %>
  <div style="color: #ff6666; margin-bottom: 15px; font-weight: bold; text-align: center;"><%= error %></div>
<% } %>
  <input type="hidden" name="token" value="<%= token %>">
  <input type="hidden" name="email" value="<%= email %>">
  
  <div class="forms-item">
    <div class="label">Новый пароль:<span class="blue">*</span></div>
    <input type="password" name="password" class="input-text" required>
    <div class="clear_both"></div>
  </div>
  <div class="forms-item" style="margin-top:20px;">
    <div class="label"></div>
    <div style="float:left;">
      <button type="submit" style="background: #333; border: 1px solid #555; padding: 5px 15px; color: #fff; font-weight: bold; cursor: pointer; border-radius: 3px;">Сохранить пароль</button>
    </div>
    <div class="clear_both"></div>
  </div>
</form>
</div>
<div class="clear_both"></div>
</div>
</div>
</div>
<div class="blackbox_bl"></div>
<div class="blackbox_bc"></div>
<div class="blackbox_br"></div>
</div>
</div>
<div class="clear_both"></div>
</div>

<%- include('partials/footer') %>
