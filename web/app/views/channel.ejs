                            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                              <% fans.forEach(fan=> { %>
                                <div style="width: 90px; text-align: center; margin-bottom: 5px;">
                                  <a href="/ru/account,userinfo?username=<%= fan.username %>"
                                    style="text-decoration: none;">
                                    <div class="border_logo" style="margin: 0 auto; width: 90px; height: 90px;">
                                      <img src="<%= CDN_BASE_URL %><%= fan.avatar  %>" style="width: 90px; height: 90px; background: #222;">
                                    </div>
                                    <div
                                      style="color: #6fdeee; font-size: 11px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-top: 5px;">
                                      <%= fan.username %>
                                    </div>
                                  </a>
                                </div>
                                <% }) %>
