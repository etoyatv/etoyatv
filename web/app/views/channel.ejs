                      <script type="text/javascript">
                        $(document).ready(function() {
                          var sizes = {
                            0: [ {w: 512, h: 288}, {w: 640, h: 360}, {w: 768, h: 432} ], // 16:9
                            1: [ {w: 384, h: 288}, {w: 480, h: 360}, {w: 576, h: 432} ]  // 4:3
                          };

                          var shortname = "<%= channel.shortname %>";
                          var protocol = window.location.protocol;
                          var hostname = window.location.host;

                          // Set initial channel URL correctly based on active host
                          $('#channelurl').val(protocol + '//' + hostname + '/' + shortname);

                          // Set initial chat embed code
                          var chatSrc = protocol + '//' + hostname + '/widget/chat/' + shortname;
                          $('#chat_embedcode').val('<iframe src="' + chatSrc + '" width="400" height="331" frameborder="0" scrolling="no"></iframe>');

                          function updateSizes() {
                            var pFormat = parseInt($('#player_format').val());
                            var available = sizes[pFormat];

                            var select = $('#player_size');
                            select.empty();

                            var ul = $('#jselect-player_size .options ul');
                            ul.empty();

                            var selectedIdx = 1; // Default to middle size
                            
                            available.forEach(function(size, idx) {
                              var text = size.w + 'x' + size.h;
                              
                              // Native option
                              var opt = $('<option>').val(idx).text(text);
                              if (idx === selectedIdx) {
                                opt.attr('selected', 'selected');
                              }
                              select.append(opt);

                              // Custom list item
                              var li = $('<li>')
                                .addClass('item_' + idx)
                                .attr('data-value', idx)
                                .text(text);
                              if (idx === selectedIdx) {
                                li.addClass('selected');
                              }
                              ul.append(li);
                            });

                            var defaultText = available[selectedIdx].w + 'x' + available[selectedIdx].h;
                            $('#jselect-player_size p').text(defaultText);
                            select.val(selectedIdx);

                            updateEmbedCode();
                          }

                          function updateEmbedCode() {
                            var pFormat = parseInt($('#player_format').val());
                            var sizeIdx = parseInt($('#player_size').val());
                            var autoplay = $('#player_autoplay').is(':checked') ? 1 : 0;

                            var sizeObj = sizes[pFormat][sizeIdx];
                            if (!sizeObj) return;
                            
                            var src = protocol + '//' + hostname + '/widget/player/' + shortname + '?autoplay=' + autoplay;
                            var iframeCode = '<iframe src="' + src + '" width="' + sizeObj.w + '" height="' + sizeObj.h + '" frameborder="0" allowfullscreen></iframe>';
                            $('#embedcode').val(iframeCode);
                          }

                          // Bind change on native select elements
                          $('#player_format').on('change', function() {
                            updateSizes();
                          });

                          $('#player_size').on('change', function() {
                            updateEmbedCode();
                          });

                          $('#player_autoplay').on('change', function() {
                            var label = $('label[for="player_autoplay"]');
                            if (this.checked) {
                              label.addClass('checked');
                            } else {
                              label.removeClass('checked');
                            }
                            updateEmbedCode();
                          });

                          // Custom styled dropdown toggle click
                          $(document).on('click', '.select-inner p', function(e) {
                            e.stopPropagation();
                            var currentOptions = $(this).siblings('.options');
                            var isClosed = currentOptions.css('left') === '-9999px';
                            $('.select-inner .options').css('left', '-9999px'); // Close all first
                            if (isClosed) {
                              currentOptions.css('left', '-1px');
                            }
                          });

                          // Custom styled dropdown items selection
                          $(document).on('click', '.select-inner .options li', function(e) {
                            e.stopPropagation();
                            var li = $(this);
                            var text = li.text();
                            var val = parseInt(li.attr('data-value'));
                            var container = li.closest('.select-outer');
                            var selectId = container.attr('id').replace('jselect-', '');
                            var nativeSelect = $('#' + selectId);

                            // Update paragraph text
                            container.find('p').text(text);
                            
                            // Set active class
                            li.addClass('selected').siblings().removeClass('selected');

                            // Close options list
                            li.closest('.options').css('left', '-9999px');

                            // Update native select and trigger change
                            nativeSelect.val(val).trigger('change');
                          });

                          $(document).on('click', function() {
                            $('.select-inner .options').css('left', '-9999px');
                          });

                          // Initial sizing trigger
                          updateSizes();
                        });
                      </script>
                      <div class="clear_both"></div>
                    </div>
                    <div class="clear_both"></div>
                  </div>
                </div>
