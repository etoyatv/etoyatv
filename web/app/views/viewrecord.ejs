        <script>
            function toggleFavorite(id) {
                if (window.toggleFavoriteRecord) {
                    window.toggleFavoriteRecord(id);
                }
            }
            
            function copyCurrentUrl() {
                const text = window.location.href;
                function fallbackCopyTextToClipboard(text) {
                    const textArea = document.createElement("textarea");
                    textArea.value = text;
                    textArea.style.top = "0";
                    textArea.style.left = "0";
                    textArea.style.position = "fixed";
                    document.body.appendChild(textArea);
                    textArea.focus();
                    textArea.select();
                    try {
                        const successful = document.execCommand('copy');
                        if (successful) {
                            alert('Ссылка скопирована в буфер обмена!');
                        } else {
                            prompt("Скопируйте ссылку:", text);
                        }
                    } catch (err) {
                        prompt("Скопируйте ссылку:", text);
                    }
                    document.body.removeChild(textArea);
                }
                
                if (navigator.clipboard && window.isSecureContext) {
                    navigator.clipboard.writeText(text).then(() => {
                        alert('Ссылка скопирована в буфер обмена!');
                    }).catch(() => fallbackCopyTextToClipboard(text));
                } else {
                    fallbackCopyTextToClipboard(text);
                }
            }
            function refreshCommentsCount(recordId) {
                fetch('/api/records/' + recordId + '/comments_count')
                .then(res => res.json())
                .then(data => {
                    if (data.success && document.getElementById('comments_count_label')) {
                        document.getElementById('comments_count_label').innerText = data.count;
                    }
                });
            }

            function loadComments(event, recordId, page) {
                if (event) event.preventDefault();
                fetch('/api/records/' + recordId + '/comments_html?cpage=' + page)
                .then(res => res.text())
                .then(html => {
                    document.getElementById('record_comments_container').innerHTML = html;
                });
            }

            function addComment(recordId) {
                const text = document.getElementById('commentText').value;
                if (!text.trim()) return;
                fetch('/api/records/' + recordId + '/comment', { 
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById('commentText').value = '';
                        loadComments(null, recordId, 1);
                        refreshCommentsCount(recordId);
                    } else {
                        alert(data.error || 'Ошибка при добавлении комментария');
                    }
                });
            }
            
            function deleteComment(recordId, commentId) {
                yatvConfirm('Вы уверены, что хотите удалить комментарий?', () => {
                    fetch('/api/records/' + recordId + '/comment/' + commentId, { method: 'DELETE' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            loadComments(null, recordId, 1);
                            refreshCommentsCount(recordId);
                        } else {
                            alert(data.error || 'Ошибка при удалении комментария');
                        }
                    });
                });
            }
        </script>
