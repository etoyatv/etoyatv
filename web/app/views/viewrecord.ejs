<script>
window.toggleFavoriteRecord = async function(recordId) {
  try {
    const res = await fetch(`/api/records/${recordId}/favorite`, { method: 'POST' });
    const data = await res.json();
    if (data.success) {
      const isFav = data.favorited; // It returns "favorited" from the API, not "isFan"!
      
      // 1. Update elements from "Другие записи телеканала" (if any)
      const countEl = document.getElementById('record_fans_count_' + recordId);
      const iconEl = document.getElementById('record_fan_icon_' + recordId);
      if (countEl) countEl.innerText = data.count;
      if (iconEl) {
        if (isFav) {
          iconEl.classList.add('active');
        } else {
          iconEl.classList.remove('active');
        }
      }
      
      // 2. Update elements from "Описание записи" (main block)
      const oldIcon = document.getElementById('favorite-icon-' + recordId);
      const oldLikes = document.getElementById('likes_count_' + recordId);
      if (oldIcon) {
          if (isFav) {
              oldIcon.style.backgroundPosition = '-80px -16px';
              oldIcon.style.opacity = '1';
          } else {
              oldIcon.style.backgroundPosition = '';
              oldIcon.style.opacity = '';
          }
      }
      if (oldLikes) {
          oldLikes.innerText = data.count + ' чел.';
      }
      
      // 3. Update player overlay button if it's the main record
      if (recordId == '<%= record.id %>') {
         const playerFavIcon = document.getElementById('player-fav-icon');
         if (playerFavIcon) {
            playerFavIcon.setAttribute('stroke', isFav ? '#f00' : '#6fdeee');
         }
      }
    } else {
      alert(data.error || 'Пожалуйста, авторизуйтесь для добавления в избранное.');
    }
  } catch (e) {
    alert('Ошибка соединения');
  }
};
</script>

