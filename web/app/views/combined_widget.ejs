<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Плеер и Чат | ЭтоЯTV</title>
  <style>
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: #000;
    }
    .widget-container {
      width: 100%;
      height: 100%;
      display: flex;
      box-sizing: border-box;
    }
    .widget-container.horizontal {
      flex-direction: row;
    }
    .widget-container.vertical {
      flex-direction: column;
    }
    iframe {
      border: none;
      margin: 0;
      padding: 0;
      display: block;
    }
    .player-frame {
      flex: 1;
      height: 100%;
      width: 100%;
    }
    .chat-frame {
      flex-shrink: 0;
    }
    .horizontal .chat-frame {
      width: 320px;
      height: 100%;
    }
    .vertical .chat-frame {
      width: 100%;
      height: 331px;
    }
  </style>
</head>
<body>
  <div class="widget-container <%= layout %>">
    <iframe class="player-frame" src="/widget/player/<%= shortname %>?autoplay=<%= autoplay %>" allowfullscreen></iframe>
    <iframe class="chat-frame" src="/widget/chat/<%= shortname %>" scrolling="no"></iframe>
  </div>
</body>
</html>
