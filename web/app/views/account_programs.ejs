<%- include('partials/header', { activeMenu: 'channels' }) %>
<style type="text/css">
.theme_default { color: #C0C0B2; }
.theme_default a { color: #6FDEEE; }
.theme_default h1, .theme_default h2, .theme_default h3, .theme_default h4, .theme_default h5 { color: #FFFFFF; }
</style>

<div id="content">

<div class="left_blocks" style="width: 60%; float: left;">
    <div class="block_item" style="margin-bottom:15px;">
        <div class="blackbox" style="width: auto;">
            <div class="blackbox_tl"></div>
            <div class="blackbox_tc"></div>
            <div class="blackbox_tr"></div>
            <div class="blackbox_cw">
                <div class="blackbox_c">
                    <div class="blackbox_ci"> 
                        <div class="block-head-bg"></div>
                        <div class="block-head">
                            <div class="block-head-right">
                                <div class="block-title">Личное расписание пользователя <%= profileUser.username %> (<span class="blue"><%= schedules ? schedules.length : 0 %></span>)</div>
                            </div>
                        </div>
                        <div class="block-content" style="padding: 10px;">
                            <div id="records_list"> 
                                <div class="records_list">
                                    <% if (locals.schedules && schedules.length > 0) { %>
                                        <% schedules.forEach((ps, idx) => { %>
                                            <div class="item <%= idx === 0 ? 'first' : '' %> <%= idx === schedules.length - 1 ? 'last item_end' : '' %>" style="padding: 15px 0; border-bottom: 1px dotted #444; position: relative; clear: both; overflow: hidden;">
                                                <div style="float: left; width: 60px; text-align: center; margin-right: 15px; padding-top: 5px;">
                                                  <% const d = new Date(ps.start_time); %>
                                                  <div style="font-size: 14px; color: #fff;"><%= ('0' + d.getHours()).slice(-2) + ':' + ('0' + d.getMinutes()).slice(-2) %></div>
                                                  <div style="font-size: 11px; color: #8c989e; margin-top: 2px;"><%= d.getDate() %> <%= ['Января','Февраля','Марта','Апреля','Мая','Июня','Июля','Августа','Сентября','Октября','Ноября','Декабря'][d.getMonth()] %></div>
                                                </div>
                                                <div class="logo" style="float: left; width: 100px; height: 100px; background: #fff; margin-right: 15px;">
                                                  <a href="/<%= ps.shortname %>" style="display: block; width: 100%; height: 100%;">
                                                    <img src="<%= CDN_BASE_URL %><%= ps.logo_url || '/images/default_channel_logo.png'  %>" style="width: 100%; height: 100%; object-fit: contain; display: block; <%= typeof ps.is_18_plus !== 'undefined' && ps.is_18_plus ? 'filter: blur(4px);' : '' %>">
                                                  </a>
                                                </div>
                                                <div class="info" style="overflow: hidden; padding-top: 2px;">
                                                    <div class="title" style="margin-bottom: 8px;"><a href="/<%= ps.shortname %>" style="color: #6FDEEE; font-size: 16px; text-decoration: none;"><%= ps.title %></a></div> 
                                                    <div class="channel" style="margin-bottom: 8px; font-size: 12px; color: #8c989e;">
                                                      Телеканал: <a href="/<%= ps.shortname %>" style="color: #6FDEEE; text-decoration: none;"><%= ps.channel_name %></a>
                                                    </div>
                                                    <div class="description" style="font-size: 12px; color: #555; margin-bottom: 15px; overflow-wrap: break-word; word-wrap: break-word; word-break: break-word;">
                                                      <%= ps.description || 'Описание передачи не заполнено' %>
                                                    </div>
                                                    <% if (locals.user) { %>
                                                    <div>
                                                      <a href="#" onclick="event.preventDefault(); toggleBookmark(<%= ps.id %>, this);" style="font-size: 12px; color: #00a0e3; text-decoration: none;">
                                                        <%= (typeof ps.is_bookmarked !== 'undefined' ? ps.is_bookmarked : false) ? 'Удалить из личного расписания' : 'Добавить в личное расписание' %>
                                                      </a>
                                                    </div>
                                                    <% } %>
                                                </div> 
                                            </div>
                                        <% }); %>
                                    <% } else { %>
                                        <p style="color: #c0c0b2;">Личное расписание пусто.</p>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                        <div class="clear_both"></div>
                    </div>
                </div>
            </div>
            <div class="blackbox_bl"></div>
            <div class="blackbox_bc"></div>
            <div class="blackbox_br"></div>
        </div>
    </div>
</div>

<div class="right_blocks" style="width: 36%; float: right; padding: 0;"> 
<div class="blocks"> 
<div class="blackbox" style="width: auto;">
<div class="blackbox_tl"></div>
<div class="blackbox_tc"></div>
<div class="blackbox_tr"></div>
<div class="blackbox_cw">
<div class="blackbox_c" style="">
<div class="blackbox_ci"> 
<div class="block-head-bg"></div>
<div class="block-head">
<div class="block-head-right">
<div class="block-title">Пользователь → <span class="darkblue"><%= profileUser.username %></span></div>
</div> 
</div>
<div class="block-content">
<div class="channelinfoblock userinfoblock">
<div class="left">
<a class="logo" href="#"><span class="border_logo">
  <% if (profileUser.avatar && profileUser.avatar !== '/images/default_user_avatar.png') { %>
    <img src="<%= CDN_BASE_URL %><%= profileUser.avatar  %>" style="width: 100px; height: 100px; object-fit: cover; position: relative; top: -1px; left: -1px;">
  <% } else { %>
    <img src="<%= CDN_BASE_URL %>/images/default_user_avatar.png" style="width: 100px; height: 100px; object-fit: cover; position: relative; top: -1px; left: -1px;">
  <% } %>
</span></a> 
</div> 
<div class="right"> 
<div class="info">
<div class="params">
<div class="label" style="width: auto; margin-right: 10px;">Telegram:</div>
<div class="value white" style="width: auto; margin-left: 0;"><%= profileUser.telegram || 'не указано' %></div>
<div class="clear_both"></div>
<div class="label" style="width: auto; margin-right: 10px;">Discord:</div>
<div class="value white" style="width: auto; margin-left: 0;"><%= profileUser.discord || 'не указано' %></div>
<div class="clear_both"></div>
</div>
</div> 
</div>
<div class="clear_both"></div> 
<div style="margin: 15px 0; color: #c0c0b2; word-wrap: break-word; overflow-wrap: break-word; word-break: break-word; white-space: pre-wrap;"><%= profileUser.about || 'Нет информации о пользователе' %></div>
<ul class="usermenu" style="margin-top: 15px;">
  <li><div class="icon s_icon_profile"></div><a href="/ru/account,userinfo/?username=<%= encodeURIComponent(profileUser.username) %>">Профиль пользователя</a></li>
  <% if (user && user.username === profileUser.username) { %>
    <li><div class="icon s_icon_profile"></div><a href="/ru/account,profile/">Настройки профиля</a></li>
  <% } %>
  <li><div class="icon s_icon_programs"></div><a href="/ru/account,programs?username=<%= encodeURIComponent(profileUser.username) %>" class="grey">Личное расписание пользователя</a></li>
  <li><div class="icon s_icon_favrecords"></div><a href="/ru/account,favrecords?username=<%= encodeURIComponent(profileUser.username) %>">Избранные записи пользователя</a></li>
  <li><div class="icon s_icon_favchannels"></div><a href="/ru/account,favchannels?username=<%= encodeURIComponent(profileUser.username) %>">Избранные телеканалы пользователя</a></li>
  <li><div class="icon s_icon_friends"></div><a href="/ru/account,friends?username=<%= encodeURIComponent(profileUser.username) %>">Друзья пользователя</a></li>
  <li class="last"><div class="icon s_icon_friends"></div><a href="/ru/account,friendof?username=<%= encodeURIComponent(profileUser.username) %>">В друзьях у пользователей</a></li>
</ul>
<div class="clear_both"></div>
</div>
</div>
<div class="clear_both"></div>
</div></div>
<div class="blackbox_bl"></div>
<div class="blackbox_bc"></div>
<div class="blackbox_br"></div>
</div>
</div>
</div>
<%- include('partials/sidebar_ad_320x240') %>
</div>
<div class="clear_both"></div>
</div>
</div>
<script>
window.toggleBookmark = async function(programId, el) {
  try {
    const res = await fetch(`/api/programs/${programId}/bookmark`, { method: 'POST' });
    const data = await res.json();
    if (data.success) {
      if (data.action === 'removed') {
        el.innerText = 'Добавить в личное расписание';
      } else {
        el.innerText = 'Удалить из личного расписания';
      }
      window.location.reload();
    } else {
      alert(data.error || 'Ошибка');
    }
  } catch (e) {
    alert('Ошибка сети');
  }
};
</script>

<%- include('partials/footer') %>
