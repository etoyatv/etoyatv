<%- include('partials/header') %>
<link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" rel="stylesheet">

<div id="content">
  <div style="margin-top: 20px;">
    <!-- Стили для табов -->
    <style>
      .settings-tabs {
        list-style: none; padding: 0; margin: 0; height: 35px;
        background: #232323; border: 1px solid #333; border-bottom: none;
      }
      .settings-tabs li {
        float: left; padding: 0 14px; line-height: 35px; color: #7d7d7d; cursor: pointer;
        border-right: 1px solid #333;
      }
      .settings-tabs li:hover { color: #fff; }
      .settings-tabs li.active { color: #fff; background: #333; }
      .settings-content {
        background: #2b2b2b; border: 1px solid #333; padding: 20px; min-height: 300px;
      }
      .settings-block { display: none; }
      .settings-block.active { display: block; }
      .forms-item-settings { margin-bottom: 15px; clear: both; overflow: hidden; }
      .forms-item-settings .label { float: left; width: 140px; color: #c0c0b2; padding-top: 5px; text-align: right; padding-right: 15px; }
      .forms-item-settings .input { float: left; width: 280px; }
      .input-text-s { width: 100%; background: #1a1a1a; border: 1px solid #111; color: #fff; padding: 4px; box-sizing: border-box; }
      .input-select { background: #1a1a1a; border: 1px solid #111; color: #fff; padding: 4px; }
      .btn-save { background: #555; color: #fff; border: 1px solid #333; padding: 5px 20px; border-radius: 10px; cursor: pointer; }
      .btn-save:hover { background: #666; }
      .info-box { background: #232323; padding: 15px; border: 1px solid #333; color: #999; font-size: 12px; margin-bottom: 20px; }
      .info-box h3 { color: #6fdeee; margin-top: 0; font-size: 14px; font-weight: normal; margin-bottom: 10px; }
      .avatar-preview { width: 100px; height: 100px; background: #333; border: 1px solid #111; display: flex; align-items: center; justify-content: center; overflow: hidden; }
      .avatar-preview img { width: 100%; height: 100%; object-fit: cover; }
      
      /* Модалка для обрезки */
      .cropper-modal-container {
        display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.8); z-index: 1000; align-items: center; justify-content: center;
      }
      .cropper-modal-box {
        background: #2b2b2b; border: 1px solid #555; padding: 20px; width: 600px; max-width: 90%;
        border-radius: 5px;
      }
      .cropper-image-container { width: 100%; max-height: 400px; margin-bottom: 20px; background: #1a1a1a; }
      .cropper-image-container img { max-width: 100%; display: block; }
    </style>

    <!-- Модальное окно кроппера -->
    <div class="cropper-modal-container" id="cropperModal">
      <div class="cropper-modal-box">
        <h3 style="color: #6fdeee; margin-top:0;">Обрезка аватара</h3>
        <div class="cropper-image-container">
          <img id="cropperImage" src="">
        </div>
        <div style="text-align: right;">
          <button type="button" class="btn-save" id="btnCancelCrop" style="background:#555; margin-right: 10px;">Отмена</button>
          <button type="button" class="btn-save" id="btnApplyCrop" style="background:#39b54a;">Применить</button>
        </div>
      </div>
    </div>

    <div class="left_blocks" style="width: 500px; float: left;">
      <ul class="settings-tabs" id="settingsTabs">
        <li class="active" data-tab="tab-profile">Профиль</li>
        <li data-tab="tab-about">О себе</li>
        <li data-tab="tab-password">Смена пароля</li>
        <% if (typeof invite_system_enabled !== 'undefined' && invite_system_enabled) { %>
        <li data-tab="tab-invites">Инвайты</li>
        <% } %>
        <li data-tab="tab-security">Безопасность</li>
      </ul>
      <div class="settings-content">
        <!-- ТАБ: ПРОФИЛЬ -->
        <div id="tab-profile" class="settings-block active">
          <% if (typeof errorNick !== 'undefined') { %><div style="color:#ff6666;margin-bottom:10px;text-align:center;"><%= errorNick %></div><% } %>
          <% if (typeof successNick !== 'undefined') { %><div style="color:#39b54a;margin-bottom:10px;text-align:center;"><%= successNick %></div><% } %>
          <% if (typeof errorProfile !== 'undefined' && errorProfile) { %>
            <div style="color: #ff6666; margin-bottom: 15px; font-weight: bold; text-align: center;"><%= errorProfile %></div>
          <% } %>
          <% if (typeof successProfile !== 'undefined' && successProfile) { %>
            <div style="color: #39b54a; margin-bottom: 15px; font-weight: bold; text-align: center;"><%= successProfile %></div>
          <% } %>

          <form action="/settings/nickname" method="POST">
            <div class="forms-item-settings">
              <div class="label">Никнейм:*</div>
              <div class="input">
                <div style="display: flex; align-items: center; gap: 10px; width: 100%;">
                  <input type="text" name="new_nickname" value="<%= profileUser.username %>" class="input-text-s" maxlength="13" pattern="[a-zA-Z0-9_-]+" title="Имя пользователя может содержать только латинские буквы, цифры, дефисы и нижние подчеркивания" required style="flex-grow: 1; width: auto;">
                  <button type="submit" class="btn-save" style="margin: 0; padding: 4px 15px; flex-shrink: 0;">Сменить</button>
                </div>
              </div>
            </div>
          </form>

          <form id="profileForm" action="/settings/profile" method="POST" enctype="multipart/form-data">
            <div class="forms-item-settings">
              <div class="label">E-Mail адрес:*</div>
              <div class="input"><input type="email" name="email" id="inputEmail" value="<%= profileUser.email %>" class="input-text-s" required></div>
            </div>
            <div class="forms-item-settings">
              <div class="label">Часовой пояс:</div>
              <div class="input">
                <% 
                  const timezones = [
                    { value: 'Pacific/Midway', label: '(GMT-11:00) Мидуэй' },
                    { value: 'Pacific/Honolulu', label: '(GMT-10:00) Гавайи' },
                    { value: 'America/Anchorage', label: '(GMT-09:00) Аляска' },
                    { value: 'America/Los_Angeles', label: '(GMT-08:00) Тихоокеанское время (США и Канада)' },
                    { value: 'America/Denver', label: '(GMT-07:00) Горное время (США и Канада)' },
                    { value: 'America/Chicago', label: '(GMT-06:00) Центральное время (США и Канада)' },
                    { value: 'America/New_York', label: '(GMT-05:00) Восточное время (США и Канада)' },
                    { value: 'America/Caracas', label: '(GMT-04:00) Каракас, Ла-Пас' },
                    { value: 'America/Argentina/Buenos_Aires', label: '(GMT-03:00) Буэнос-Айрес' },
                    { value: 'Atlantic/South_Georgia', label: '(GMT-02:00) Среднеатлантическое время' },
                    { value: 'Atlantic/Azores', label: '(GMT-01:00) Азорские острова' },
                    { value: 'Europe/London', label: '(GMT+00:00) Лондон, Дублин, Лиссабон' },
                    { value: 'Europe/Berlin', label: '(GMT+01:00) Берлин, Рим, Париж' },
                    { value: 'Europe/Kiev', label: '(GMT+02:00) Киев, Афины, Иерусалим' },
                    { value: 'Europe/Moscow', label: '(GMT+03:00) Москва, Минск, Багдад' },
                    { value: 'Asia/Dubai', label: '(GMT+04:00) Дубай, Баку, Самара' },
                    { value: 'Asia/Yekaterinburg', label: '(GMT+05:00) Екатеринбург, Ташкент' },
                    { value: 'Asia/Omsk', label: '(GMT+06:00) Омск, Алматы, Дакка' },
                    { value: 'Asia/Krasnoyarsk', label: '(GMT+07:00) Красноярск, Бангкок' },
                    { value: 'Asia/Irkutsk', label: '(GMT+08:00) Иркутск, Пекин, Сингапур' },
                    { value: 'Asia/Yakutsk', label: '(GMT+09:00) Якутск, Токио, Сеул' },
                    { value: 'Asia/Vladivostok', label: '(GMT+10:00) Владивосток, Сидней' },
                    { value: 'Asia/Magadan', label: '(GMT+11:00) Магадан, Соломоновы острова' },
                    { value: 'Pacific/Auckland', label: '(GMT+12:00) Окленд, Фиджи' },
                    { value: 'Pacific/Tongatapu', label: '(GMT+13:00) Нукуалофа' }
                  ];
                  let userTz = profileUser.timezone || 'Europe/Moscow';
                  if (!timezones.find(t => t.value === userTz)) userTz = 'Europe/Moscow';
                %>
                <select name="timezone" class="input-text-s" style="width: 100%; max-width: 300px;">
                  <% timezones.forEach(tz => { %>
                    <option value="<%= tz.value %>" <%= userTz === tz.value ? 'selected' : '' %>><%= tz.label %></option>
                  <% }); %>
                </select>
              </div>
            </div>
            <div class="forms-item-settings">
              <div class="label">Дата рождения:</div>
              <div class="input">
                <input type="date" name="birthdate" id="inputBirthdate" class="input-text-s" value="<%= profileUser.birthdate ? new Date(profileUser.birthdate).toISOString().split('T')[0] : '' %>">
              </div>
            </div>
            <div class="forms-item-settings">
              <div class="label">Фотография:</div>
              <div class="input">
                <div class="avatar-preview" style="margin-bottom: 10px;">
                  <img id="avatarPreviewImg" src="<%= CDN_BASE_URL %><%= profileUser.avatar || '/images/default_user_avatar.png'  %>" alt="Avatar">
                </div>
                <input type="file" name="avatar" id="avatarInput" accept="image/*" style="color: #fff;">
                <div style="font-size: 11px; color: #777; margin-top: 5px;">Загружайте только JPG, PNG. Макс размер исходника до 4МБ.</div>
              </div>
            </div>
            
            <div class="forms-item-settings" style="text-align: center; margin-top: 20px;">
              <button type="submit" class="btn-save">Сохранить</button>
            </div>
          </form>

          <div style="font-size: 15px; color: #ff4d4d; margin-top: 30px; margin-bottom: 15px; border-bottom: 1px solid #444; padding-bottom: 5px; font-weight: bold;">
            Опасная зона
          </div>

          <div style="background-color: #1a1a1a; border: 1px solid #ff4d4d; padding: 15px; border-radius: 4px; margin-bottom: 20px;">
            <p style="color: #999; margin-bottom: 15px; font-size: 12px; line-height: 1.5; text-align: left;">
              Удаление аккаунта приведет к безвозвратному удалению всех ваших данных, включая созданные телеканалы, видео, новости и настройки. Это действие необратимо.
            </p>
            <% if (typeof hasBannedChannel !== 'undefined' && hasBannedChannel) { %>
              <button type="button" class="btn-save" style="background:#cc0000; cursor: not-allowed; border-color: #aa0000;" onclick="yatvConfirm('Вы не можете удалить аккаунт, так как ваш телеканал заблокирован.', () => {});">Удалить аккаунт</button>
            <% } else { %>
              <button type="button" class="btn-save" style="background:#cc0000; border-color: #aa0000;" onclick="yatvConfirm('Вы уверены, что хотите удалить аккаунт? Ваш телеканал (если есть) также будет удален! Это действие необратимо.', () => { document.getElementById('deleteAccountForm').submit(); });">Удалить аккаунт</button>
            <% } %>
          </div>

          <form id="deleteAccountForm" action="/settings/delete-account" method="POST" style="display:none;"></form>

        </div>

        <!-- ТАБ: О СЕБЕ -->
        <div id="tab-about" class="settings-block">
          <% if (typeof errorAbout !== 'undefined' && errorAbout) { %>
            <div style="color: #ff6666; margin-bottom: 15px; font-weight: bold; text-align: center;"><%= errorAbout %></div>
          <% } %>
          <% if (typeof successAbout !== 'undefined' && successAbout) { %>
            <div style="color: #39b54a; margin-bottom: 15px; font-weight: bold; text-align: center;"><%= successAbout %></div>
          <% } %>

          <form action="/settings/about" method="POST">
            <div class="forms-item-settings">
              <div class="label">Telegram:</div>
              <div class="input"><input type="text" name="telegram" value="<%= profileUser.telegram || '' %>" class="input-text-s"></div>
            </div>
            <div class="forms-item-settings">
              <div class="label">Discord:</div>
              <div class="input"><input type="text" name="discord" value="<%= profileUser.discord || '' %>" class="input-text-s"></div>
            </div>
            <div class="forms-item-settings">
              <div class="label">О себе:</div>
              <div class="input"><textarea name="about" class="input-text-s" style="height: 100px; resize: vertical;" maxlength="200"><%= profileUser.about || '' %></textarea></div>
            </div>
            <div class="forms-item-settings" style="text-align: center; margin-top: 20px;">
              <button type="submit" class="btn-save">Сохранить</button>
            </div>
          </form>
        </div>

        <!-- ТАБ: СМЕНА ПАРОЛЯ -->
        <div id="tab-password" class="settings-block">
          <% if (typeof errorPassword !== 'undefined' && errorPassword) { %>
            <div style="color: #ff6666; margin-bottom: 15px; font-weight: bold; text-align: center;"><%= errorPassword %></div>
          <% } %>
          <% if (typeof successPassword !== 'undefined' && successPassword) { %>
            <div style="color: #39b54a; margin-bottom: 15px; font-weight: bold; text-align: center;"><%= successPassword %></div>
          <% } %>
          <form action="/settings/password" method="POST">
            <div class="forms-item-settings">
              <div class="label">Старый пароль:*</div>
              <div class="input"><input type="password" name="oldPassword" class="input-text-s" required></div>
            </div>
            <div class="forms-item-settings">
              <div class="label">Новый пароль:*</div>
              <div class="input"><input type="password" name="newPassword" class="input-text-s" minlength="6" required></div>
            </div>
            <div class="forms-item-settings" style="text-align: center; margin-top: 20px;">
              <button type="submit" class="btn-save">Сохранить</button>
            </div>
          </form>
        </div>

        <% if (typeof invite_system_enabled !== 'undefined' && invite_system_enabled) { %>
        <!-- ТАБ: ИНВАЙТЫ -->
        <div id="tab-invites" class="settings-block">
          <% if (typeof errorInvite !== 'undefined' && errorInvite) { %><div style="color:#ff6666;margin-bottom:10px;text-align:center;"><%= errorInvite %></div><% } %>
          <% if (typeof successInvite !== 'undefined' && successInvite) { %><div style="color:#39b54a;margin-bottom:10px;text-align:center;"><%= successInvite %></div><% } %>
          <form action="/settings/invites/generate" method="POST" style="margin-bottom: 20px;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <div>
                <h3 style="color: #6fdeee; margin: 0 0 5px 0;">Ваши Инвайт-коды</h3>
                <p style="color: #999; font-size: 12px; margin: 0;">Вы можете сгенерировать до 2 кодов в день.</p>
              </div>
              <button type="submit" class="btn-save" style="background: #0072ff; border-color: #00c6ff;">Сгенерировать код</button>
            </div>
          </form>

          <table style="width: 100%; border-collapse: collapse; font-size: 12px; color: #ccc;">
            <thead>
              <tr style="border-bottom: 1px solid #333;">
                <th style="padding: 8px; text-align: left;">Код</th>
                <th style="padding: 8px; text-align: left;">Статус</th>
                <th style="padding: 8px; text-align: left;">Использовал</th>
                <th style="padding: 8px; text-align: left;">Дата</th>
                <th style="padding: 8px; text-align: left;">Действия</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof invites !== 'undefined' && invites.length > 0) { %>
                <% invites.forEach(inv => { %>
                  <tr style="border-bottom: 1px solid #222;">
                    <td style="padding: 8px; font-family: monospace;"><%= inv.code %></td>
                    <td style="padding: 8px;">
                      <% if (inv.used_at) { %>
                        <span style="color: #f87171;">Использован</span>
                      <% } else { %>
                        <span style="color: #4ade80;">Активен</span>
                      <% } %>
                    </td>
                    <td style="padding: 8px;">
                      <%= inv.used_by_name ? inv.used_by_name : '-' %>
                    </td>
                    <td style="padding: 8px;"><%= typeof userTimezone !== 'undefined' ? formatDate(inv.created_at, userTimezone, 'DD.MM.YYYY') : formatDate(inv.created_at, profileUser.timezone, 'DD.MM.YYYY') %></td>
                    <td style="padding: 8px;">
                      <% if (!inv.used_at) { %>
                        <form action="/ru/account,profile/invites/delete/<%= inv.id %>" method="POST" onsubmit="event.preventDefault(); const form = this; yatvConfirm('Вы уверены, что хотите удалить этот код?', () => { form.submit(); });" style="display:inline;">
                          <button type="submit" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); padding: 2px 6px; border-radius: 4px; cursor: pointer; font-size: 11px;">Удалить</button>
                        </form>
                      <% } else { %>
                        <span style="color: #666; font-size: 11px;">Недоступно</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="5" style="padding: 15px; text-align: center; color: #777;">У вас еще нет инвайт-кодов.</td>
                </tr>
              <% } %>
            </tbody>
          </table>

          <% if (typeof totalInvitePages !== 'undefined' && totalInvitePages > 1) { %>
            <div style="margin-top: 20px; text-align: center;">
              <% for(let i=1; i<=totalInvitePages; i++) { %>
                <a href="?invite_page=<%= i %>#tab-invites" style="display: inline-block; padding: 5px 10px; margin: 0 2px; background: <%= (typeof invitePage !== 'undefined' && invitePage === i) ? '#6fdeee' : '#333' %>; color: <%= (typeof invitePage !== 'undefined' && invitePage === i) ? '#000' : '#fff' %>; text-decoration: none; border-radius: 3px;"><%= i %></a>
              <% } %>
            </div>
          <% } %>
        </div>
        <% } %>

        <!-- ТАБ: БЕЗОПАСНОСТЬ -->
        <div id="tab-security" class="settings-block">
          <% if (typeof error2FA !== 'undefined') { %><div style="color:#ff6666;margin-bottom:10px;text-align:center;"><%= error2FA %></div><% } %>
          
          <div class="info-box">
            <h3>Двухфакторная аутентификация (2FA)</h3>
            <p>Дополнительный уровень безопасности для вашего аккаунта. При входе потребуется вводить временный код из приложения (например, Google Authenticator).</p>
            
            <% if (profileUser.is_totp_enabled) { %>
              <div style="margin-top: 15px; color: #39b54a; font-weight: bold;">
                Статус: Включено
              </div>
              <div style="margin-top: 20px; border-top: 1px solid #333; padding-top: 15px;">
                <p style="color: #ff6666; margin-bottom: 10px;">Для отключения 2FA введите текущий код из приложения или резервный код:</p>
                <form action="/account/2fa/disable" method="POST" style="display: flex; align-items: center; gap: 10px;">
                  <input type="text" name="code" class="input-text-s" placeholder="Код или резервный код" autocomplete="off" required style="width: 200px; text-align: center; letter-spacing: 1px;">
                  <button type="submit" class="btn-save" style="background: #ff4d4d; border-color: #cc0000; margin: 0;">Отключить 2FA</button>
                </form>
              </div>
            <% } else { %>
              <div style="margin-top: 15px; color: #ff6666; font-weight: bold;">
                Статус: Отключено
              </div>
              <div style="margin-top: 20px;">
                <a href="/account/2fa/setup" class="btn-save" style="display: inline-block; text-decoration: none;">Настроить 2FA</a>
              </div>
            <% } %>
          </div>
        </div>

      </div>
    </div>

    <!-- RIGHT BLOCKS -->
    <div class="right_blocks" style="width: 320px; float: right; padding: 0;">
      <div class="info-box">
        <h3>Укажите Вашу контактную информацию!</h3>
        <p><strong>Электронная почта</strong><br>
        Указанный при регистрации адрес электронной почты не предназначен для публичного отображения, а будет использован администрацией ЭтоЯTV при необходимости срочного оповещения пользователей о нововведениях и изменениях, связанных с работой сайта и функционалом платформы.</p>
        <p style="margin-top: 15px;"><strong>Фотография пользователя</strong><br>
        Загруженное изображение будет отображаться в качестве аватара на Вашей личной странице и в Ваших сообщениях. Оригинальный размер изображения не должен превышать 100x100 пикселей.</p>
      </div>
    </div>
    <div class="clear_both"></div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
<script>
  // Cropper logic
  const avatarInput = document.getElementById('avatarInput');
  const cropperModal = document.getElementById('cropperModal');
  const cropperImage = document.getElementById('cropperImage');
  const btnCancelCrop = document.getElementById('btnCancelCrop');
  const btnApplyCrop = document.getElementById('btnApplyCrop');
  const avatarPreviewImg = document.getElementById('avatarPreviewImg');
  let cropper;

  avatarInput.addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    
    const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp'];
    const allowedExtensions = ['.jpg', '.jpeg', '.png', '.gif', '.webp'];
    const extension = file.name.substring(file.name.lastIndexOf('.')).toLowerCase();

    if (!allowedTypes.includes(file.type) && !allowedExtensions.includes(extension)) {
      alert("Неподдерживаемый формат файла. Разрешена загрузка только изображений (jpeg, jpg, png, gif, webp).");
      this.value = '';
      return;
    }

    if (file.size > 4 * 1024 * 1024) {
      alert("Размер файла превышает 4 МБ.");
      this.value = '';
      return;
    }

    const reader = new FileReader();
    reader.onload = function(event) {
      cropperImage.src = event.target.result;
      cropperModal.style.display = 'flex';
      
      if (cropper) cropper.destroy();
      cropper = new Cropper(cropperImage, {
        aspectRatio: 1,
        viewMode: 1
      });
    };
    reader.readAsDataURL(file);
  });

  btnCancelCrop.addEventListener('click', function() {
    cropperModal.style.display = 'none';
    if (cropper) cropper.destroy();
    avatarInput.value = '';
  });

  btnApplyCrop.addEventListener('click', function() {
    if (!cropper) return;
    
    const canvas = cropper.getCroppedCanvas({
      width: 100,
      height: 100,
      imageSmoothingEnabled: true,
      imageSmoothingQuality: 'high'
    });
    
    canvas.toBlob(function(blob) {
      const file = new File([blob], "avatar.jpg", { type: "image/jpeg" });
      const dataTransfer = new DataTransfer();
      dataTransfer.items.add(file);
      avatarInput.files = dataTransfer.files;
      
      avatarPreviewImg.src = canvas.toDataURL("image/jpeg");
      
      cropperModal.style.display = 'none';
      cropper.destroy();
    }, "image/jpeg", 0.9);
  });

  // Tabs logic
  const tabs = document.querySelectorAll('#settingsTabs li');
  const blocks = document.querySelectorAll('.settings-block');
  
  let activeTabId = window.location.hash ? window.location.hash.substring(1) : 'tab-profile';
  if (!document.getElementById(activeTabId)) activeTabId = 'tab-profile';
  
  tabs.forEach(tab => {
    if (tab.getAttribute('data-tab') === activeTabId) tab.classList.add('active');
    else tab.classList.remove('active');
    
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      blocks.forEach(b => b.classList.remove('active'));
      
      tab.classList.add('active');
      const target = document.getElementById(tab.getAttribute('data-tab'));
      target.classList.add('active');
      window.location.hash = tab.getAttribute('data-tab');
    });
  });
  
  blocks.forEach(block => {
    if (block.id === activeTabId) block.classList.add('active');
    else block.classList.remove('active');
  });
</script>

