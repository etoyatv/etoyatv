<%- include('partials/header') %>

<style>
  .password-container {
    max-width: 400px;
    margin: 100px auto;
    background: #2a3135;
    padding: 30px;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.5);
    text-align: center;
    border: 1px solid #3c464c;
  }
  .password-container h2 {
    color: #fff;
    margin-bottom: 20px;
    font-size: 20px;
  }
  .password-container p {
    color: #8c989e;
    font-size: 14px;
    margin-bottom: 20px;
  }
  .password-container .form-control {
    width: 100%;
    padding: 10px;
    background: #1a1e20;
    border: 1px solid #3c464c;
    color: #fff;
    border-radius: 4px;
    margin-bottom: 15px;
    box-sizing: border-box;
  }
  .password-container .btn {
    width: 100%;
    padding: 10px;
    background: #3b9cd9;
    color: #fff;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
    font-weight: bold;
  }
  .password-container .btn:hover {
    background: #2a88c2;
  }
  .error-msg {
    color: #ff4d4d;
    margin-bottom: 15px;
    font-size: 13px;
  }
</style>

<div class="password-container">
  <h2>Телеканал «<%= channel.name %>» защищен паролем</h2>
  <p>Пожалуйста, введите пароль для доступа к трансляции.</p>
  
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="error-msg"><%= error %></div>
  <% } %>

  <form action="/api/channels/<%= channel.shortname %>/unlock" method="POST">
    <input type="password" name="password" class="form-control" placeholder="Пароль" required autofocus>
    <button type="submit" class="btn">Получить доступ</button>
  </form>
</div>

<%- include('partials/footer') %>
