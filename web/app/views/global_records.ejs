<%- include('partials/header') %>

    <div id="content" style="flex: 1 0 auto;">
        <!-- LEFT COLUMN>> -->
        <div class="left_blocks">
            <div class="block_item">
                <div class="blackbox" style="width: auto;">
                    <div class="blackbox_tl"></div>
                    <div class="blackbox_tc"></div>
                    <div class="blackbox_tr"></div>
                    <div class="blackbox_cw">
                        <div class="blackbox_c" style="">
                            <div class="blackbox_ci">
                                <div class="block-head-bg"></div>
                                <div class="block-head">
                                    <div class="block-head-right">
                                        <div class="block-title">Записи <%= searchQuery ? '- по запросу "' + searchQuery
                                                + '"' : '' %>
                                        </div>
                                    </div>
                                </div>
                                <div class="block-content">
                                    <div id="records_list">
                                        <div class="records_list" style="padding: 10px;">
                                            <% if (records.length===0) { %>
                                                <div style="padding: 20px; text-align: center; color: #888;">Записи не
                                                    найдены.</div>
                                                <% } else { %>
                                                    <% records.forEach(function(rec, index) { %>
                                                        <div
                                                            class="item <%= index === 0 ? 'first' : '' %> <%= index === records.length - 1 ? 'last item_end' : '' %>">
                                                            <div class="record_item" style="position: relative;" style="position: relative;">
                                                                <a href="/ru/tv,viewrecord,<%= rec.id %>" class="thumb"
                                                                    style="background: #000 url('<%= CDN_BASE_URL %><%= rec.thumbnail_url || '/images/default_record_thumb.png' %>') no-repeat center center; background-size: cover; position: relative; overflow: hidden;">
                                                                    <% if (rec.is_18_plus) { %>
                                                                    <div style="position: absolute; top: -5px; left: -5px; right: -5px; bottom: -5px; backdrop-filter: blur(5px); background: rgba(0,0,0,0.1); z-index: 1;"></div>
                                                                    <% } %>
                                                                    <span class="border_thumb" style="position: relative; z-index: 2;">
                                                                        <div class="record_time">
                                                                            <%= ('0' + Math.floor(rec.duration /
                                                                                3600)).slice(-2) %>:<%= ('0' +
                                                                                    Math.floor((rec.duration % 3600) /
                                                                                    60)).slice(-2) %>:<%= ('0' +
                                                                                        (rec.duration % 60)).slice(-2)
                                                                                        %>
                                                                        </div>
                                                                    </span>
                                                                </a>
                                                                <div class="info">
                                                                    <div class="title"><a
                                                                            href="/ru/tv,viewrecord,<%= rec.id %>">
                                                                            <%= rec.title %>
                                                                        </a><% if(rec.is_18_plus) { %> <span class="label_18" style="display:inline-block; vertical-align:middle; margin-left:5px; margin-top:0; float:none;"></span><% } %></div>
                                                                    <div class="channel"><span
                                                                            class="label">Телеканал:</span> <a
                                                                            href="/<%= rec.shortname %>">
                                                                            <%= rec.channel_name %>
                                                                        </a></div>
                                                                    <div class="date"><span class="label">Дата:</span>
                                                                        <span class="white">
                                                                            <%= ('0' + new
                                                                                Date(rec.created_at).getDate()).slice(-2)
                                                                                %>.<%= ('0' + (new
                                                                                    Date(rec.created_at).getMonth() +
                                                                                    1)).slice(-2) %>.<%= new
                                                                                        Date(rec.created_at).getFullYear()
                                                                                        %>
                                                                        </span></div>
                                                                    <div class="views"><span
                                                                            class="label">Просмотров:</span> <span
                                                                            class="white">
                                                                            <%= rec.views %>
                                                                        </span></div>
                                                                </div>
                                <div style="position: absolute; right: 0; top: 0;">
                                  <% if (locals.user) { %>
                                  <div class="likes-badge">
                                    <span id="record_fans_count_<%= rec.id %>" style="color:#fff; font-size:10px; font-weight:bold; line-height: 18px; padding-top: 1px;"><%= rec.fans_count || 0 %></span>
                                    <a href="#" onclick="toggleFavoriteRecord('<%= rec.id %>'); return false;" style="display: flex; align-items: center; justify-content: center; width: 16px; height: 16px; text-decoration: none;"><span class="block-head-icon-heart heart-btn <%= rec.is_fan ? 'active' : '' %>" id="record_fan_icon_<%= rec.id %>" style="display: block; width: 16px; height: 16px; margin: 0; padding: 0;"></span></a>
                                  </div>
                                  <% } %>
                                </div>

                                                            </div>
                                                            <div class="clear_both"></div>
                                                        </div>
                                                        <% }); %>
                                                            <% } %>
                                        </div>

                                        <!-- Pager Navigator -->
                                        <div class="pager">
                                            <% if (totalPages> 1) { %>
                                                <% if (currentPage> 1) { %>
                                                    <div style="float:left;">
                                                        <div class="item prev"><a
                                                                href="/ru/tv,records?page=<%= currentPage - 1 %><%= searchQuery ? '&q='+searchQuery : '' %>">Предыдущая</a>
                                                        </div>
                                                    </div>
                                                    <% } %>

                                                        <% for(let i=1; i<=totalPages; i++) { %>
                                                            <% if (i===currentPage) { %>
                                                                <div class="item active">
                                                                    <%= i %>
                                                                </div>
                                                                <% } else if (i===1 || i===totalPages || (i>=
                                                                    currentPage - 2 && i <= currentPage + 2)) { %>
                                                                        <div class="item"><a
                                                                                href="/ru/tv,records?page=<%= i %><%= searchQuery ? '&q='+searchQuery : '' %>">
                                                                                <%= i %>
                                                                            </a></div>
                                                                        <% } else if (i===currentPage - 3 ||
                                                                            i===currentPage + 3) { %>
                                                                            <div class="item">...</div>
                                                                            <% } %>
                                                                                <% } %>

                                                                                    <% if (currentPage < totalPages) {
                                                                                        %>
                                                                                        <div style="float:right;">
                                                                                            <div class="item next"><a
                                                                                                    href="/ru/tv,records?page=<%= currentPage + 1 %><%= searchQuery ? '&q='+searchQuery : '' %>">Следующая</a>
                                                                                            </div>
                                                                                        </div>
                                                                                        <% } %>
                                                                                            <% } %>
                                                                                                <div class="clear_both">
                                                                                                </div>
                                        </div>
                                        <!-- Pager Navigator -->
                                    </div>
                                </div>
                                <div class="clear_both"></div>
                            </div>
                            <div class="clear_both"></div>
                        </div>
                        <div class="clear_both"></div>
                    </div>
                    <div class="blackbox_bl"></div>
                    <div class="blackbox_bc"></div>
                    <div class="blackbox_br"></div>
                </div>

            </div>
        </div>
        <!-- << LEFT COLUMN -->
        <!-- RIGHT COLUMN>> -->
        <div class="right_blocks">
            <div class="blocks">
                <div class="blackbox" style="width: auto;">
                    <div class="blackbox_tl"></div>
                    <div class="blackbox_tc"></div>
                    <div class="blackbox_tr"></div>
                    <div class="blackbox_cw">
                        <div class="blackbox_c" style="">
                            <div class="blackbox_ci">
                                <div class="block-head-bg"></div>
                                <div class="block-head">
                                    <div class="block-head-right">
                                        <div class="block-title">Реклама</div>
                                    </div>
                                </div>
                                <div class="block-content">
                                    <% if (adsEnabled && adsConfig['sidebar_320x240'] && adsConfig['sidebar_320x240'].image) { %>
                                      <div style="width: 320px; display: flex; align-items: center; justify-content: center; margin: 0 auto;">
                                        <% if (adsConfig['sidebar_320x240'].url) { %>
                                          <a href="<%= adsConfig['sidebar_320x240'].url %>" target="_blank" style="display: block;">
                                            <img src="<%= adsConfig['sidebar_320x240'].image %>" style="max-width: 100%;">
                                          </a>
                                        <% } else { %>
                                          <img src="<%= adsConfig['sidebar_320x240'].image %>" style="max-width: 100%;">
                                        <% } %>
                                      </div>
                                    <% } else if (!adsEnabled) { %>
                                      <!-- Ad is disabled -->
                                    <% } else { %>
                                      <div style="width: 320px; height: 240px; background: #333; display: flex; align-items: center; justify-content: center; color: #777; margin: 0 auto;">Место для рекламы</div>
                                    <% } %>
                                    <div class="clear_both"></div>
                                </div>
                                <div class="clear_both"></div>
                            </div>
                        </div>
                    </div>
                    <div class="blackbox_bl"></div>
                    <div class="blackbox_bc"></div>
                    <div class="blackbox_br"></div>
                </div>

            </div>
        </div>
        <!-- << RIGHT COLUMN -->
        <div class="clear_both"></div>
    </div>

    
<script>
window.toggleFavoriteRecord = async function(recordId) {
  try {
    const res = await fetch(`/api/records/${recordId}/favorite`, { method: 'POST' });
    const data = await res.json();
    if (data.success) {
      const countEl = document.getElementById('record_fans_count_' + recordId);
      const iconEl = document.getElementById('record_fan_icon_' + recordId);
      if (countEl) countEl.innerText = data.count;
      if (iconEl) {
        if (data.isFan) {
          iconEl.classList.add('active');
        } else {
          iconEl.classList.remove('active');
        }
      }
    } else {
      alert(data.error || 'Ошибка');
    }
  } catch (e) {
    alert('Ошибка соединения');
  }
};
</script>

<%- include('partials/footer') %>

