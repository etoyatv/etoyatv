<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : '404 - Страница не найдена' %></title>
  <link rel="icon" href="/images/admin_favicon.svg" type="image/svg+xml">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>

  <%- include('partials/header') %>

  <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: calc(100vh - 70px); padding: 40px; box-sizing: border-box; background: #1a1e20;">
    <div style="text-align: center; max-width: 600px;">
      <h1 style="font-size: 140px; font-weight: 900; color: #ff4d4d; margin: 0; line-height: 1; text-shadow: 0 0 40px rgba(255, 77, 77, 0.2);">404</h1>
      <h2 style="font-size: 28px; color: #fff; margin: 20px 0 10px 0; font-weight: bold;">Страница не найдена</h2>
      <p style="color: #8c989e; margin: 0 0 30px 0; font-size: 16px; line-height: 1.5;">
        Запрашиваемая страница <code style="background: rgba(0,0,0,0.3); padding: 4px 8px; border-radius: 4px; color: #ff4d4d; word-break: break-all;"><%= currentPath %></code> не существует или была удалена.
      </p>
      <a href="/" style="display: inline-block; text-decoration: none; padding: 14px 32px; font-size: 16px; background: #00c6ff; color: #000; font-weight: bold; border-radius: 6px; transition: all 0.2s ease; box-shadow: 0 4px 15px rgba(0, 198, 255, 0.2);">На главную</a>
    </div>
  </div>

</body>
</html>
