<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Блокировки пользователей | Панель управления</title>
  <link rel="stylesheet" href="/css/admin.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <%- include('partials/header') %>
  <div class="layout-container">
    <%- include('partials/sidebar', { currentPath: '/bans/users' }) %>
    <main class="main-content">
      <style>
        .table-container {
          background: rgba(255, 255, 255, 0.03);
          border: 1px solid rgba(255, 255, 255, 0.1);
          border-radius: 12px;
          overflow: hidden;
          margin-top: 20px;
        }
        table {
          width: 100%;
          border-collapse: collapse;
          font-size: 14px;
        }
        th, td {
          padding: 12px 15px;
          text-align: left;
          border-bottom: 1px solid rgba(255, 255, 255, 0.05);
          word-break: break-word;
          white-space: normal;
        }
        th {
          font-weight: 600;
          color: #9ca3af;
          background: rgba(0,0,0,0.2);
        }
        tr:last-child td {
          border-bottom: none;
        }
        .btn-action {
          padding: 8px 15px;
          cursor: pointer;
        }
      </style>

      <div class="content-header">
        <h1>Блокировки пользователей</h1>
      </div>

      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Юзер (ID)</th>
              <th>Кем выдан</th>
              <th>Причина</th>
              <th>Срок</th>
              <th>Действие</th>
            </tr>
          </thead>
          <tbody>
            <% bans.forEach(b => { %>
              <tr>
                <td>
                  <a href="/users/<%= b.id %>/edit" style="color: white; text-decoration: none;">
                    <strong><%= b.username %></strong> <span style="color: #888;">(ID: <%= b.id %>)</span>
                  </a>
                </td>
                <td>
                  <% if (b.banned_by_username) { %>
                    <%= b.banned_by_username %>
                  <% } else { %>
                    <span style="color: #888;">Система</span>
                  <% } %>
                </td>
                <td>
                  <%= b.ban_reason ? b.ban_reason : 'Не указана' %>
                </td>
                <td>
                  <% if (b.banned_until) { %>
                    до <%= formatDate(b.banned_until, userTimezone, 'DD.MM.YYYY HH:mm:ss') %>
                  <% } else { %>
                    <span style="color: #ff4d4d;">Бессрочно</span>
                  <% } %>
                </td>
                <td>
                  <form action="/users/<%= b.id %>/ban" method="POST" style="display: inline;">
                    <input type="hidden" name="ban_type" value="unban">
                    <button type="submit" class="btn-action btn-danger" onclick="event.preventDefault(); const form = this.closest('form'); yatvConfirm('Вы уверены, что хотите разблокировать этого пользователя?', () => { form.submit(); });">Разблокировать</button>
                  </form>
                </td>
              </tr>
            <% }); %>
            <% if (bans.length === 0) { %>
              <tr>
                <td colspan="5" style="text-align: center; padding: 30px; color: #888;">
                  Блокировок не найдено
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Pagination & Limits -->
      <div class="pagination-section" style="margin-top: 20px;">
        <form action="/bans/users" method="GET" class="limit-selector">
          <% if (typeof search !== 'undefined' && search) { %>
            <input type="hidden" name="search" value="<%= search %>">
          <% } %>
          <label>На страницу: </label>
          <select name="limit" class="custom-select" onchange="this.form.submit()">
            <option value="10" <%= limit === 10 ? 'selected' : '' %>>10</option>
            <option value="25" <%= limit === 25 ? 'selected' : '' %>>25</option>
            <option value="50" <%= limit === 50 ? 'selected' : '' %>>50</option>
            <option value="100" <%= limit === 100 ? 'selected' : '' %>>100</option>
          </select>
        </form>

        <div class="pagination">
          <% if (page > 1) { %>
            <a href="/bans/users?<%= typeof search !== 'undefined' && search ? 'search=' + search + '&' : '' %>page=<%= page - 1 %>&limit=<%= limit %>" class="page-link">Предыдущая</a>
          <% } %>
          
          <span class="page-current">Страница <%= page %> из <%= totalPages %></span>
          
          <% if (page < totalPages) { %>
            <a href="/bans/users?<%= typeof search !== 'undefined' && search ? 'search=' + search + '&' : '' %>page=<%= page + 1 %>&limit=<%= limit %>" class="page-link">Следующая</a>
          <% } %>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
