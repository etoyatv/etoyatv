  <header class="top-nav">
    <a href="/" style="display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; overflow: hidden; border-radius: 5px; margin-right: 30px;">
      <img src="<%= CDN_BASE_URL %>/images/favicon.svg" alt="" style="width: 100%; height: 100%; object-fit: contain;">
    </a>
    
    <button class="mobile-menu-toggle" onclick="document.getElementById('mobileNav').classList.toggle('show')">☰</button>
    
    <div class="nav-wrapper" id="mobileNav">
      <nav class="nav-links">
        <% const isModOnly = user && !user.is_superadmin && user.staff_role === 'moderator'; %>
        <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Главная</a>
        <a href="/users" class="<%= currentPath.startsWith('/users') || currentPath.startsWith('/bans') || currentPath.startsWith('/staff') ? 'active' : '' %>">Пользователи</a>
        <a href="/channels" class="<%= currentPath && currentPath.startsWith('/channels') ? 'active' : '' %>">Каналы</a>
        <a href="/records" class="<%= currentPath && currentPath.startsWith('/records') ? 'active' : '' %>">Записи</a>
        <a href="/news" class="<%= currentPath && currentPath.startsWith('/news') ? 'active' : '' %>">Новости</a>
        <a href="/announces" class="<%= currentPath && currentPath.startsWith('/announces') ? 'active' : '' %>">Анонсы</a>
        <% if (!isModOnly && typeof invite_system_enabled !== 'undefined' && invite_system_enabled) { %>
        <a href="/invites" class="<%= currentPath === '/invites' ? 'active' : '' %>">Инвайт-коды</a>
        <% } %>
        <a href="/reports" class="<%= currentPath && currentPath.startsWith('/reports') ? 'active' : '' %>">Жалобы</a>
        <a href="/settings#personal" class="<%= currentPath === '/settings' ? 'active' : '' %>">Настройки</a>
        <a href="/logs" class="<%= currentPath === '/logs' ? 'active' : '' %>">Логи</a>
      </nav>
      
      <div class="divider"></div>
      
      <div class="profile-section">
        <div class="avatar" style="background-image: url('<%= CDN_BASE_URL %><%= user && user.avatar ? user.avatar : '/images/default_user_avatar.png' %>'); background-size: cover; background-position: center;"></div>
        <div class="user-info">
          <span class="user-name"><%= user ? user.username : 'Гость' %></span>
          <span class="user-role"><%= user && user.staff_role === 'admin' ? 'Администратор' : 'Модератор' %></span>
        </div>
      </div>
    </div>
    

  </header>
  
  <% if (typeof currentPath !== 'undefined' && currentPath === '/') { %>
  <div class="action-toolbar-wrapper" style="display: flex; justify-content: flex-end; margin-top: -20px; margin-bottom: 20px; width: 100%; max-width: 1400px;">
    <div class="action-toolbar">
      <a href="<%= APP_URL %>" target="_blank" title="Перейти на сайт">
        <button><svg viewBox="0 0 24 24"><path d="M12 2L2 12h3v8h6v-6h2v6h6v-8h3L12 2z"/></svg></button>
      </a>
      <a href="/settings#personal" title="Настройки">
        <button><svg viewBox="0 0 24 24"><path d="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.06-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.73,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.06,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.43-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.49-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"/></svg></button>
      </a>
      <a href="/logout" title="Выход">
        <button><svg viewBox="0 0 24 24"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg></button>
      </a>
    </div>
  </div>
  <% } %>

  <%- include('flash') %>
