<div id="yatv-confirm-modal-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 99999; align-items: center; justify-content: center; font-family: 'Inter', sans-serif;">
  <div style="background: #1e1e2d; width: 400px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 8px 32px rgba(0,0,0,0.5); overflow: hidden; color: #fff;">
    <div style="background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.05); padding: 15px 20px; font-weight: 600; font-size: 15px; display: flex; justify-content: space-between; align-items: center;">
      <span>Подтверждение действия</span>
      <span style="cursor: pointer; font-size: 20px; line-height: 1; color: rgba(255,255,255,0.5);" onclick="document.getElementById('yatv-confirm-modal-overlay').style.display='none';">&times;</span>
    </div>
    <div style="padding: 20px;">
      <p style="margin: 0 0 20px; font-size: 14px; color: rgba(255,255,255,0.8); line-height: 1.5;" id="yatv-confirm-message">Вы уверены?</p>
      
      <div style="margin-top: 25px; display: flex; justify-content: flex-end; gap: 10px;">
        <button id="yatv-confirm-cancel-btn" style="padding: 8px 16px; border: 1px solid rgba(255,255,255,0.2); background: transparent; color: #fff; cursor: pointer; border-radius: 6px; font-size: 13px; font-weight: 500; transition: all 0.2s;">Отмена</button>
        <button id="yatv-confirm-submit-btn" style="padding: 8px 16px; border: none; background: #e74c3c; color: #fff; cursor: pointer; border-radius: 6px; font-weight: 600; font-size: 13px; transition: all 0.2s;">ОК</button>
      </div>
    </div>
  </div>
</div>

<script>
  window.yatvConfirm = function(message, onConfirm) {
    const overlay = document.getElementById('yatv-confirm-modal-overlay');
    const msgEl = document.getElementById('yatv-confirm-message');
    const submitBtn = document.getElementById('yatv-confirm-submit-btn');
    const cancelBtn = document.getElementById('yatv-confirm-cancel-btn');

    msgEl.innerText = message || 'Вы уверены?';
    
    const newSubmitBtn = submitBtn.cloneNode(true);
    submitBtn.parentNode.replaceChild(newSubmitBtn, submitBtn);

    const newCancelBtn = cancelBtn.cloneNode(true);
    cancelBtn.parentNode.replaceChild(newCancelBtn, cancelBtn);

    newSubmitBtn.onclick = function() {
      overlay.style.display = 'none';
      if (typeof onConfirm === 'function') {
        onConfirm();
      }
    };

    newCancelBtn.onclick = function() {
      overlay.style.display = 'none';
    };

    overlay.style.display = 'flex';
  };
</script>
